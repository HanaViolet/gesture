/* ===== 分析结果页面：清晰专业设计 ===== */

.result-page {
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-primary);
  box-sizing: border-box;
}

/* 进度条区域 */
.progress-wrapper {
  margin-bottom: var(--space-4);
}

.progress-wrapper progress {
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.progress-text {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-2);
  font-weight: 500;
}

.progress-text.done {
  color: var(--care-green);
}

/* 结果卡片 */
.result-card {
  flex: 1;
  padding: var(--space-5);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  display: flex;
  flex-direction: column;
}

.result-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--space-3);
  font-weight: 500;
}

.result-textarea {
  flex: 1;
  width: 100%;
  min-height: 200rpx;
  font-size: var(--font-lg);
  color: var(--text-primary);
  line-height: 1.7;
  background: transparent;
  font-weight: 500;
}

/* 语音操作区 */
.voice-actions {
  display: flex;
  gap: var(--space-5);
  margin-top: var(--space-5);
}

.voice-btn {
  flex: 1;
  height: 160rpx;
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  transition: all var(--duration-fast) var(--ease-out);
  box-shadow: var(--shadow-sm);
}

.voice-btn:active {
  transform: scale(0.97);
}

.voice-btn.male {
  background: var(--brand-light);
  color: var(--brand-dark);
}

.voice-btn.male.active {
  background: var(--gradient-primary);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.voice-btn.female {
  background: var(--accent-light);
  color: var(--accent-dark);
}

.voice-btn.female.active {
  background: var(--gradient-warm);
  color: #fff;
  box-shadow: var(--shadow-warm);
}

.voice-btn.disabled {
  background: var(--bg-secondary);
  color: var(--text-muted);
  pointer-events: none;
}

.voice-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.voice-btn text {
  font-size: var(--font-base);
  font-weight: 600;
}

/* 底部操作区 */
.result-footer {
  display: flex;
  gap: var(--space-4);
  margin-top: var(--space-5);
  padding-bottom: env(safe-area-inset-bottom);
}

.footer-btn {
  flex: 1;
  height: 100rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
}

.footer-btn.primary {
  background: var(--gradient-primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
}

.footer-btn.primary:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 159, 0.25);
}

.footer-btn.secondary {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.footer-btn.secondary:active {
  background: var(--bg-tertiary);
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .result-card {
    border: 4rpx solid var(--text-primary);
  }

  .voice-btn {
    border: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .voice-btn,
  .footer-btn {
    transition: none;
  }
}
