.result-page {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.progress-wrapper {
  margin-bottom: 24rpx;
}

.progress-wrapper progress {
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.progress-text.done {
  color: var(--success);
}

.result-card {
  flex: 1;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.result-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.result-textarea {
  flex: 1;
  width: 100%;
  min-height: 200rpx;
  font-size: 32rpx;
  color: var(--text);
  line-height: 1.6;
  background: transparent;
}

.voice-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 32rpx;
}

.voice-btn {
  flex: 1;
  height: 144rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 200ms ease;
}

.voice-btn.male {
  background: #E3F2FD;
  color: #1A3A5C;
}

.voice-btn.male.active {
  background: #1A3A5C;
  color: #fff;
}

.voice-btn.female {
  background: #FCE4EC;
  color: #880E4F;
}

.voice-btn.female.active {
  background: #C2185B;
  color: #fff;
}

.voice-btn.disabled {
  background: #F5F5F5;
  color: #BBB;
  pointer-events: none;
}

.voice-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.result-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
