<view class="container">
  <!-- 进度条 -->
  <progress style="position: relative; left: 0rpx; top: 43rpx" percent="{{progress}}" show-info="true" />
  <!-- 可编辑的聊天文本 -->
  <view class="chat-container" style="position: fixed; left: 375rpx; top: 116rpx">
    <view class="chat-content" style="position: relative; left: 0rpx; top: 0rpx;">
      <view class="chat-text" style=" margin-bottom: 70rpx">{{convertingText}}</view> 
      <view style="height: 941rpx; display: block; box-sizing: border-box; left: 0rpx; top: 0rpx">
        <input style="height: 202rpx; display: block; box-sizing: border-box" type="text" bindinput="onChatTextInput" value="{{chatTexts}}" placeholder="编辑聊天文本"/>
        <button bindtap="saveToCommonPhrases" style="position: relative; left: 0rpx; top: 230rpx">保存至常用语</button>
        <button bindtap="confirmEdit" style="position: relative; left: 0rpx; top: 256rpx">生成语音</button>
        <!-- 男声播放按钮 -->
        <button 
          bindtap="playMaleVoice" 
          class="{{!maleAudioUrl? 'disabled-btn' : (selectedVoice ==='male'? 'male-btn-selected' :'male-btn')}}"
          disabled="{{!maleAudioUrl}}"
          style="position: relative; left: -153rpx; top: 281rpx; width: 256rpx; display: block; box-sizing: border-box; height: 304rpx"
        >
        <image src="/images/标准男声.png" mode="aspectFit" class="fixed-size-image" style="width: 174rpx; height: 218rpx; display: inline-block; box-sizing: border-box"></image>
          男声播放
        </button>
        <!-- 女声播放按钮 -->
        <button 
          bindtap="playFemaleVoice" 
          class="{{!femaleAudioUrl? 'disabled-btn' : (selectedVoice === 'female'? 'female-btn-selected' : 'female-btn')}}"
          disabled="{{!femaleAudioUrl}}"
          style="position: relative; left: 153rpx; top: -24rpx; width: 256rpx; display: block; box-sizing: border-box; height: 304rpx"
        >
        <image src="/images/标准女声.png" mode="aspectFit" class="fixed-size-image" style="width: 174rpx; height: 218rpx; display: inline-block; box-sizing: border-box"></image>
          女声播放
        </button>
      </view>
    </view>
  </view>
</view>