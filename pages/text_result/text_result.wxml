<view class="page-full result-page">
  <view class="progress-wrapper">
    <progress percent="{{progress}}" stroke-width="8" activeColor="#007AFF" backgroundColor="#E3F2FD" show-info="{{false}}"/>
    <text class="progress-text" wx:if="{{progress < 100 && progress > 0}}"
    >合成中 {{progress}}%</text>
  </view>

  <view class="result-card card-shadow">
    <view class="result-hint">
      <block wx:if="{{quickMode}}">输入快捷短语文字</block>
      <block wx:elif="{{saveAsPhrase}}">输入常用语文字</block>
      <block wx:else>输入文字，可生成语音</block>
    </view>
    <textarea class="result-textarea" placeholder="在此输入文字..." value="{{inputText}}" bindinput="onTextInput" maxlength="500"/>

    <view class="voice-actions" wx:if="{{!quickMode}}">
      <view class="voice-btn male {{!maleAudioUrl ? 'disabled' : (selectedVoice === 'male' ? 'active' : '')}}" bindtap="playMaleVoice">
        <image src="/images/male_icon.svg" mode="aspectFit" class="voice-icon-img"/>
        <text>男声</text>
      </view>
      <view class="voice-btn female {{!femaleAudioUrl ? 'disabled' : (selectedVoice === 'female' ? 'active' : '')}}" bindtap="playFemaleVoice">
        <image src="/images/female_icon.svg" mode="aspectFit" class="voice-icon-img"/>
        <text>女声</text>
      </view>
    </view>
  </view>

  <view class="result-footer">
    <view wx:if="{{quickMode}}" class="footer-btn btn-primary press" bindtap="saveQuickPhrase">
      <text>保存为快捷短语</text>
    </view>
    <view wx:elif="{{saveAsPhrase}}" class="footer-btn btn-secondary press" bindtap="saveAsCommonPhrase">
      <text>保存为常用语</text>
    </view>
    <view wx:if="{{!quickMode}}" class="footer-btn btn-primary press" bindtap="confirmEdit">
      <text>生成语音</text>
    </view>
  </view>
</view>
