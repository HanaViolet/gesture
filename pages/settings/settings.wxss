/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 分组区域 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #666;
  padding: 24rpx 32rpx 16rpx;
  font-weight: 500;
}

/* 列表 */
.list {
  background-color: #fff;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.label {
  font-size: 32rpx;
  color: #333;
}

.list-item-right {
  display: flex;
  align-items: center;
}

.value {
  font-size: 30rpx;
  color: #666;
  margin-right: 12rpx;
}

.arrow {
  font-size: 28rpx;
  color: #999;
}

/* 开关样式 */
switch {
  transform: scale(0.9);
}

/* 底部弹出选择器遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 选择器内容 */
.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-content.show {
  transform: translateY(0);
}

/* 选择器头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

/* 选择器列表 */
.picker-list {
  max-height: 60vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item.active {
  background-color: #f8f9fa;
}

.picker-item-text {
  font-size: 32rpx;
  color: #333;
  flex: 1;
}

.picker-item-desc {
  font-size: 26rpx;
  color: #999;
  margin-right: 48rpx;
}

.picker-item-check {
  font-size: 32rpx;
  color: #6da4df;
  font-weight: bold;
}

/* 高对比度模式 */
.high-contrast .container {
  background-color: #000;
}

.high-contrast .section-title {
  color: #fff;
}

.high-contrast .list {
  background-color: #000;
}

.high-contrast .list-item {
  border-bottom-color: #333;
}

.high-contrast .label {
  color: #fff;
}

.high-contrast .value {
  color: #ccc;
}

.high-contrast .picker-content {
  background-color: #000;
}

.high-contrast .picker-header {
  border-bottom-color: #333;
}

.high-contrast .picker-title {
  color: #fff;
}

.high-contrast .picker-item {
  border-bottom-color: #333;
}

.high-contrast .picker-item.active {
  background-color: #1a1a1a;
}

.high-contrast .picker-item-text {
  color: #fff;
}
