/* ===== 设置页面：现代极简设计 ===== */

.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: var(--space-6);
}

/* ===== 分组区域 ===== */
.section {
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  padding: var(--space-4) var(--space-5) var(--space-3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* ===== 列表 ===== */
.list {
  background: var(--bg-elevated);
  margin: 0 var(--space-4);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  overflow: hidden;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 2rpx solid var(--bg-secondary);
  transition: background var(--duration-fast);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: var(--bg-secondary);
}

.list-item-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 40rpx;
  margin-right: var(--space-3);
  width: 56rpx;
  text-align: center;
}

/* 关于语见 - 应用logo */
.app-logo {
  width: 48rpx;
  height: 48rpx;
  margin-right: var(--space-3);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-xs);
}

.label {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.list-item-right {
  display: flex;
  align-items: center;
}

.value {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  margin-right: var(--space-2);
}

.arrow {
  font-size: var(--font-base);
  color: var(--text-muted);
}

/* ===== 开关样式 ===== */
switch {
  transform: scale(0.85);
}

/* ===== 底部弹出选择器遮罩 ===== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 68, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all var(--duration-normal) var(--ease-out);
  backdrop-filter: blur(4rpx);
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

/* ===== 选择器内容 ===== */
.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  transform: translateY(100%);
  transition: transform var(--duration-normal) var(--ease-spring);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(44, 62, 68, 0.15);
}

.picker-content.show {
  transform: translateY(0);
}

/* 拖拽指示条 */
.picker-content::before {
  content: '';
  position: absolute;
  top: var(--space-2);
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: 4rpx;
}

/* ===== 选择器头部 ===== */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-6) var(--space-5) var(--space-4);
  border-bottom: 2rpx solid var(--bg-secondary);
}

.picker-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.picker-close {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  padding: var(--space-2);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  border-radius: 50%;
  transition: all var(--duration-fast);
}

.picker-close:active {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

/* ===== 选择器列表 ===== */
.picker-list {
  max-height: 60vh;
  overflow-y: auto;
  padding-top: var(--space-2);
}

.picker-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 2rpx solid var(--bg-secondary);
  position: relative;
  transition: background var(--duration-fast);
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item:active {
  background: var(--bg-secondary);
}

.picker-item.active {
  background: var(--brand-soft);
}

.picker-item-text {
  font-size: var(--font-lg);
  color: var(--text-primary);
  flex: 1;
  font-weight: 500;
}

.picker-item-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-right: var(--space-5);
}

.picker-item-check {
  font-size: var(--font-lg);
  color: var(--brand-primary);
  font-weight: bold;
}

/* ===== 高对比度模式 ===== */
.high-contrast .container {
  background: #000;
}

.high-contrast .section-title {
  color: #fff;
}

.high-contrast .list {
  background: #000;
  border-color: #333;
}

.high-contrast .list-item {
  border-bottom-color: #333;
}

.high-contrast .label {
  color: #fff;
}

.high-contrast .value {
  color: #ccc;
}

.high-contrast .picker-content {
  background: #000;
}

.high-contrast .picker-header {
  border-bottom-color: #333;
}

.high-contrast .picker-title {
  color: #fff;
}

.high-contrast .picker-item {
  border-bottom-color: #333;
}

.high-contrast .picker-item.active {
  background: #1a1a1a;
}

.high-contrast .picker-item-text {
  color: #fff;
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .list {
    border: 4rpx solid var(--text-primary);
  }

  .list-item {
    border-bottom: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .picker-mask,
  .picker-content {
    transition: none;
  }
}
