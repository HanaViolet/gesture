.popularization-container {
  height: 100vh;
  background: #e6f0ff; /* 浅蓝色背景 */
}

.back-button {
  position: fixed;
  top: 20px;
  left: 15px;
  z-index: 100;
  width: 30px;
  height: 30px;
}

.content-scroll {
  height: 100vh;
  padding: 10px 20px 30px; /* 左右距离屏幕边缘 30px */
}

.section-card {
  width: calc(100vw - 40px); /* 左右两边各 20px，所以减去 40px */
  background: white;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 15px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

.section-header {
  background: #cddff5; /* 浅蓝色标题背景 */
  padding: 15px;
  font-size: 20px;
  font-weight: bold;
  color: #333;
}

.section-content {
  padding: 15px;
  font-size: 16px;
  line-height: 1.6;
  color: #666;
  word-break: break-all; /* 让文本自动换行 */
  white-space: normal;    /* 正常处理空白，配合 word-break 实现自动换行 */
}