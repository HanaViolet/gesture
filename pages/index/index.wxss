.onboarding {
  position: relative;
}

.onboarding-swiper {
  width: 100vw;
  height: 100vh;
}

.onboarding-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.onboarding-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0 64rpx;
  box-sizing: border-box;
}

.illustration {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: var(--primary-light);
  margin-bottom: 64rpx;
  position: relative;
  overflow: hidden;
}

/* 共情插画 */
.empathy .hand-icon {
  position: absolute;
  width: 80rpx;
  height: 100rpx;
  border: 6rpx solid var(--primary);
  border-radius: 20rpx 20rpx 40rpx 40rpx;
  background: rgba(255,255,255,0.6);
}

.empathy .hand-icon.left {
  left: 70rpx;
  top: 110rpx;
  transform: rotate(-15deg);
}

.empathy .hand-icon.right {
  right: 70rpx;
  top: 110rpx;
  transform: rotate(15deg);
}

.empathy .wave-line {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.empathy .wave-line::before,
.empathy .wave-line::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
  opacity: 0.5;
}

.empathy .wave-line::before { top: -16rpx; }
.empathy .wave-line::after { bottom: -16rpx; }

/* 功能插画 */
.feature .figure-outline {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 240rpx;
  border: 4rpx solid var(--primary);
  border-radius: 80rpx 80rpx 60rpx 60rpx;
  background: rgba(255,255,255,0.4);
}

.feature .joint {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 50%;
}

.feature .joint-1 { left: 120rpx; top: 140rpx; }
.feature .joint-2 { left: 200rpx; top: 120rpx; }
.feature .joint-3 { left: 160rpx; top: 200rpx; }

.onboarding-title {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text);
  text-align: center;
  margin-bottom: 24rpx;
}

.onboarding-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

.mode-btn {
  width: 100%;
  max-width: 480rpx;
  height: 104rpx;
  border-radius: 52rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(0, 122, 255, 0.12);
}

.indicator {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #D8D8D8;
  transition: all 300ms ease;
}

.dot.active {
  width: 40rpx;
  background: var(--primary);
}
