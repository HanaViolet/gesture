<view class="page-full onboarding">
  <swiper class="onboarding-swiper" bindchange="onSwipeChange">
    <!-- 第一屏：共情 -->
    <swiper-item class="onboarding-item">
      <view class="onboarding-content">
        <view class="illustration empathy">
          <view class="hand-icon left"></view>
          <view class="hand-icon right"></view>
          <view class="wave-line"></view>
        </view>
        <view class="onboarding-title">打破无声的隔阂</view>
        <view class="onboarding-subtitle">让每一次手语，都被温柔地听见</view>
      </view>
    </swiper-item>

    <!-- 第二屏：功能 -->
    <swiper-item class="onboarding-item">
      <view class="onboarding-content">
        <view class="illustration feature">
          <view class="figure-outline"></view>
          <view class="joint joint-1"></view>
          <view class="joint joint-2"></view>
          <view class="joint joint-3"></view>
        </view>
        <view class="onboarding-title">将文字转化为灵动的手语</view>
        <view class="onboarding-subtitle">AI 驱动的 3D 手语生成，沟通从未如此自然</view>
      </view>
    </swiper-item>

    <!-- 第三屏：选择 -->
    <swiper-item class="onboarding-item">
      <view class="onboarding-content">
        <view class="onboarding-title" style="margin-bottom: 24rpx;">请选择您的身份</view>
        <view class="onboarding-subtitle" style="margin-bottom: 80rpx;">我们将为您定制最适合的交互方式</view>

        <view class="mode-btn btn-secondary press" data-mode="normal" bindtap="chooseMode">
          <text>我是健听人</text>
        </view>
        <view class="mode-btn btn-secondary press" data-mode="deaf" bindtap="chooseMode" style="margin-top: 32rpx;">
          <text>我是听障人士</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 指示器 -->
  <view class="indicator">
    <view class="dot {{current === 0 ? 'active' : ''}}"></view>
    <view class="dot {{current === 1 ? 'active' : ''}}"></view>
    <view class="dot {{current === 2 ? 'active' : ''}}"></view>
  </view>
</view>
