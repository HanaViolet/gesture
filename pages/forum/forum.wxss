.forum-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(to bottom, #e0f7fa, #ffffff);
}

.header {
  padding: 20px;
  font-size: 24px;
  font-weight: bold;
  color: #00796b;
  text-align: center;
  background: #b2dfdb;
}

.post-list {
  flex: 1;
  padding: 15px;
  overflow-y: auto;
}

.post-card {
  background: #ffffff;
  width: 85%;
  border-radius: 10px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  padding: 15px;
  margin-bottom: 15px;
  transition: transform 0.2s;
}

.post-card:hover {
  transform: scale(1.02);
}

.post-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
}

.post-content {
  font-size: 14px;
  color: #666;
  margin-bottom: 12px;
}

.post-image {
  width: 100%;
  height: 200px;
  border-radius: 10px;
  margin-bottom: 10px;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #999;
}

.like-button {
  margin-top: 8px;
  font-size: 14px;
  color: #f44336;
}

.new-post-button {
  background: linear-gradient(to right, #4facfe, #00f2fe);
  color: white;
  font-size: 18px;
  text-align: center;
  padding: 15px 0;
  border-radius: 50px;
  margin: 10px 20px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
}
