/* ===== 社区论坛：温暖社交设计 ===== */

.forum-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: 100%;
  background: var(--bg-primary);
  padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== 论坛头部 ===== */
.forum-header {
  padding: var(--space-5);
  background: var(--bg-elevated);
  border-bottom: 2rpx solid var(--bg-tertiary);
  box-shadow: var(--shadow-xs);
}

.forum-title {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--text-primary);
}

.forum-subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-1);
}

/* ===== 帖子列表 ===== */
.post-list {
  flex: 1;
  padding: var(--space-4) var(--space-4) 0;
  box-sizing: border-box;
}

/* ===== 合作社区宣传区域 ===== */
.community-banner-section {
  margin-bottom: var(--space-5);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  display: block;
}

.community-swiper {
  height: 320rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.community-banner {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-xl);
  display: block;
}

.banner-overlay {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: var(--space-6) var(--space-4) var(--space-4);
  background: linear-gradient(to top, rgba(44, 62, 68, 0.7) 0%, transparent 100%);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.banner-title {
  font-size: var(--font-md);
  color: #fff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ===== 帖子卡片 ===== */
.post-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  margin: 0 0 var(--space-4) 0;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  transition: all var(--duration-fast) var(--ease-out);
  box-sizing: border-box;
}

.post-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow);
}

.post-category {
  display: inline-block;
  padding: var(--space-1) var(--space-3);
  background: var(--brand-light);
  color: var(--brand-primary);
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-3);
  font-weight: 600;
}

.post-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
  line-height: 1.4;
}

.post-content {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: var(--space-4);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-4);
  display: block;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-4);
  border-top: 2rpx solid var(--bg-secondary);
}

.post-author-wrapper {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.post-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  border: 2rpx solid var(--bg-tertiary);
}

.post-author {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.post-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.post-stats {
  display: flex;
  gap: var(--space-4);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.stat-icon {
  width: 28rpx;
  height: 28rpx;
}

/* ===== 发帖按钮 ===== */
.new-post-button {
  position: fixed;
  right: var(--space-5);
  bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg), var(--shadow-glow);
  z-index: 100;
  transition: all var(--duration-fast) var(--ease-out);
}

.new-post-button:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.new-post-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.new-post-text {
  font-size: var(--font-xs);
  color: #fff;
  font-weight: 600;
}

/* ===== 空状态 ===== */
.empty-state {
  padding: var(--space-8) var(--space-5);
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: var(--space-4);
  opacity: 0.3;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

/* ===== 加载状态 ===== */
.loading-more {
  text-align: center;
  padding: var(--space-4);
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .post-card {
    border: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .post-card,
  .new-post-button {
    transition: none;
  }
}
