.forum-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-primary, #FAF9F7);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 论坛头部 */
.forum-header {
  padding: 32rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--bg-secondary, #F2F0ED);
}

.forum-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #2D2D2D);
}

.forum-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary, #5A5A5A);
  margin-top: 8rpx;
}

/* 帖子列表 */
.post-list {
  flex: 1;
  padding: 24rpx;
}

.post-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: transform 200ms ease;
}

.post-card:active {
  transform: scale(0.98);
}

.post-category {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: var(--morandi-blue-light, #B8C4CE);
  color: var(--morandi-blue, #7A8B99);
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #2D2D2D);
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.post-content {
  font-size: 28rpx;
  color: var(--text-secondary, #5A5A5A);
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--bg-secondary, #F2F0ED);
}

.post-author {
  font-size: 24rpx;
  color: var(--text-secondary, #5A5A5A);
}

.post-time {
  font-size: 22rpx;
  color: var(--text-tertiary, #8A8A8A);
}

.post-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #5A5A8A);
}

.stat-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 发帖按钮 */
.new-post-button {
  position: fixed;
  right: 40rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--gradient-daily);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(122, 139, 153, 0.35);
  z-index: 100;
}

.new-post-button:active {
  transform: scale(0.95);
}

.new-post-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.new-post-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary, #8A8A8A);
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--text-tertiary, #8A8A8A);
}
