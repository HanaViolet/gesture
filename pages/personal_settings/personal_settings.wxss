.container {
  padding: 20px;
  background-color: #f9f9f9;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.avatar-wrapper {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  overflow: hidden;
  margin: 30px auto 20px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.info-section {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #e0e0e0;
}

.info-label {
  font-size: 16px;
  color: #333;
  flex-shrink: 0;
  width: 100px;
}

.info-value {
  font-size: 16px;
  color: #666;
  text-align: right;
  flex: 1;
}

.selectable {
  color: #6da4df;
}

.logout-button {
  margin-top: 50px;
  margin-left: 20px;
  margin-right: 20px;
  padding: 16px 0;
  background-color: #ff4d4f;
  color: #fff;
  text-align: center;
  border-radius: 10px;
  font-size: 20px;
  font-weight: bold;
  width: calc(100% - 40px);
  align-self: center;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 8px;
  padding: 20px;
}

.modal-input {
  width: 100%;
  border: 1px solid #ccc;
  border-radius: 6px;
  margin-bottom: 12px;
  padding: 8px;
  font-size: 16px;
}

.code-row {
  display: flex;
  gap: 8px;
  align-items: center;
}

.send-code {
  padding: 8px 12px;
  background-color: #6da4df;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 14px;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 16px;
}

.confirm {
  background-color: #6cb37c;
  color: white;
  flex: 1;
  margin-right: 8px;
  padding: 10px 0;
  border-radius: 6px;
}

.cancel {
  background-color: #ccc;
  flex: 1;
  padding: 10px 0;
  border-radius: 6px;
}
