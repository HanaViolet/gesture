<view class="detail-container" wx:if="{{post}}">
  <!-- 帖子头部 -->
  <view class="post-header">
    <view class="category-tag">{{post.category || '分享'}}</view>
    <view class="title">{{post.title}}</view>
    <view class="author-info">
      <image class="author-avatar" src="{{post.avatar}}" mode="aspectFill"/>
      <view class="author-meta">
        <view class="author-name">{{post.author}}</view>
        <view class="author-time">{{post.time}}</view>
      </view>
    </view>
  </view>

  <!-- 帖子内容 -->
  <view class="content-section">
    <view class="content">{{post.content}}</view>

    <view class="post-images" wx:if="{{post.images.length}}">
      <block wx:for="{{post.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="detail-img" bindtap="previewImage" data-url="{{item}}"/>
      </block>
    </view>
  </view>

  <!-- 互动栏 -->
  <view class="interaction-bar">
    <view class="interaction-btn {{isLiked ? 'active' : ''}}" bindtap="likePost">
      <image src="/icons/heart{{isLiked ? '-fill' : ''}}.svg" mode="aspectFit" class="interaction-icon"/>
      <text class="interaction-text">{{post.likes || 0}}</text>
    </view>
    <view class="interaction-btn">
      <image src="/icons/message.svg" mode="aspectFit" class="interaction-icon"/>
      <text class="interaction-text">{{post.commentCount}}</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="comment-header">
      {{t('forum.comments')}}
      <text class="comment-count">({{post.commentCount}})</text>
    </view>

    <view class="comment-list">
      <block wx:if="{{post.commentCount == 0}}">
        <view class="comment-empty">
          <text>{{t('forum.commentEmpty')}}</text>
        </view>
      </block>

      <block wx:for="{{post.comments}}" wx:key="id">
        <view class="comment-item">
          <image class="comment-avatar" src="{{item.avatar}}" mode="aspectFill"/>
          <view class="comment-body">
            <view>
              <text class="comment-author">{{item.user || '匿名'}}</text>
              <text class="comment-time">{{item.time}}</text>
            </view>
            <view class="comment-content">{{item.content}}</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 评论输入 -->
  <view class="comment-input-area">
    <input
      class="comment-input"
      placeholder="{{t('forum.commentPlaceholder')}}"
      value="{{commentInput}}"
      bindinput="onCommentInput"
      confirm-type="send"
      bindconfirm="submitComment"
    />
    <view class="send-btn {{!commentInput ? 'disabled' : ''}}" bindtap="submitComment">
      {{t('forum.send')}}
    </view>
  </view>
</view>
