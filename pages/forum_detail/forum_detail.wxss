.detail-container {
  min-height: 100vh;
  background: var(--bg-primary, #FAF9F7);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 帖子头部 */
.post-header {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: var(--morandi-amber-light, #E8D4B8);
  color: var(--morandi-amber, #D4A373);
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary, #2D2D2D);
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.author-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.author-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--morandi-blue-light, #B8C4CE);
  border: 2rpx solid var(--bg-secondary, #F2F0ED);
}

.author-meta {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  color: var(--text-primary, #2D2D2D);
  font-weight: 500;
}

.author-time {
  font-size: 24rpx;
  color: var(--text-tertiary, #8A8A8A);
  margin-top: 4rpx;
}

/* 帖子内容 */
.content-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.content {
  font-size: 30rpx;
  color: var(--text-primary, #2D2D2D);
  line-height: 1.8;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* 互动区域 */
.interaction-bar {
  background: #fff;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-around;
  border-bottom: 1rpx solid var(--bg-secondary, #F2F0ED);
}

.interaction-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background: var(--bg-secondary, #F2F0ED);
}

.interaction-btn.active {
  background: var(--morandi-amber-light, #E8D4B8);
}

.interaction-icon {
  width: 36rpx;
  height: 36rpx;
}

.interaction-text {
  font-size: 26rpx;
  color: var(--text-secondary, #5A5A5A);
}

.interaction-btn.active .interaction-text {
  color: var(--morandi-amber, #D4A373);
}

/* 评论区 */
.comment-section {
  background: #fff;
  padding: 32rpx;
  min-height: 400rpx;
}

.comment-header {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #2D2D2D);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--bg-secondary, #F2F0ED);
}

.comment-count {
  font-size: 24rpx;
  color: var(--text-tertiary, #8A8A8A);
  font-weight: normal;
  margin-left: 8rpx;
}

.comment-list {
  padding-bottom: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--bg-secondary, #F2F0ED);
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--morandi-blue-light, #B8C4CE);
  border: 2rpx solid var(--bg-secondary, #F2F0ED);
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-author {
  font-size: 26rpx;
  color: var(--text-primary, #2D2D2D);
  font-weight: 500;
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-tertiary, #8A8A8A);
  margin-left: 12rpx;
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-secondary, #5A5A5A);
  line-height: 1.6;
  margin-top: 8rpx;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 40rpx;
}

.comment-empty text {
  font-size: 26rpx;
  color: var(--text-tertiary, #8A8A8A);
}

/* 评论输入区域 */
.comment-input-area {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--bg-secondary, #F2F0ED);
  display: flex;
  gap: 16rpx;
  align-items: center;
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-secondary, #F2F0ED);
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: var(--text-primary, #2D2D2D);
}

.comment-input::placeholder {
  color: var(--text-tertiary, #8A8A8A);
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: var(--gradient-daily);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.send-btn:active {
  opacity: 0.9;
}
