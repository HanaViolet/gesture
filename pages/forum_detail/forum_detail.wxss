.detail-container {
  padding: 20px;
  background: #ffffff;
  min-height: 100vh;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 10px;
  color: #333;
}

.author-time {
  font-size: 14px;
  color: #888;
  margin-bottom: 20px;
}

.content {
  font-size: 16px;
  color: #555;
  line-height: 1.6;
  margin-bottom: 20px;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 20px;
}

.detail-img {
  width: 100px;
  height: 100px;
  border-radius: 8px;
}

.comment-section {
  margin-top: 30px;
}

.comment-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 10px;
}

.comment-item {
  padding: 8px;
  background: #f5f5f5;
  border-radius: 6px;
  margin-bottom: 10px;
  font-size: 14px;
}

.comment-input-area {
  display: flex;
  margin-top: 15px;
  gap: 8px;
}

.comment-input-area input {
  flex: 1;
  border: 1px solid #ccc;
  border-radius: 8px;
  padding: 8px;
}

.comment-input-area button {
  background: #00bcd4;
  color: white;
  border-radius: 8px;
  padding: 8px 15px;
}
