.container {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background-color: #fff8eb; /* 之前设置的背景颜色，可按需调整 */
  padding-bottom: 50px; /* 根据自定义导航栏高度调整，假设导航栏高度为50px */
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -999;
}

.camera-button-wrapper {
  position: fixed;
  top: 7vh;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.camera-button {
  width: 150px;
  height: 150px;
  border-radius: 12px;
  /* 浅紫色到浅蓝色的径向渐变背景 */
  background: radial-gradient(circle,#ecd4d2  0%, #e3edfa 100%);
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
}

.fixed-size-image {
  max-width: 75%;
  max-height: 75%;
}

.phrase-card {
  position: fixed;
  bottom: 30px !important; /* 底部到屏幕底部边缘的距离 */
  left: 15px; /* 左侧到屏幕边缘的距离 */
  right: 15px; /* 右侧到屏幕边缘的距离 */
  height: 450px; /* 固定常用语框的高度 */
  /* 浅紫色到浅蓝色的斜线渐变背景 */
  background: linear-gradient(135deg, #f0d2d0 0%, #bde1e5 100%);
  border-radius: 10px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  padding: 15px;
  display: flex;
  flex-direction: column;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  overflow-y: auto;
  z-index: 1;
}

.card-title {
  font-size: 22px;
  margin-bottom: 20px;
  color: rgb(0, 0, 0);
}

.gif-scroll-container {
  flex: 1;
  overflow-y: auto;
}

.gif-container {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.gif-row {
  display: flex;
  gap: 10px;
}

.gif-item {
  width: calc(50% - 5px);
  aspect-ratio: 4 / 3;
  border: 1px solid #e0e0e0;
  border-radius: 5px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gif-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.time {
  position: relative;
  bottom: auto;
  left: auto;
  font-size: 12px;
  color: #666;
  background-color: white;
  padding: 2px;
  width: 100%;
  text-align: center;
}

.placeholder {
  border: none;
  background: transparent;
}

.plus-icon-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 40%;
  height: 40%;
  position: relative; /* 设置相对定位 */
  top: 35px; /* 向下偏移 10px */
}

.plus-icon-small {
  width: 30%;
  height: 30%;
}

@media (min-width: 768px) {
 .phrase-card {
      /* 可根据需要调整不同屏幕尺寸下的样式 */
      bottom: 20px;
      left: 20px;
      right: 20px;
  }
}

/* 切换图标的样式 */
.switch-icon {
  position: absolute;
  top: 10px;
  left: 10px;
  width: 30px;
  height: 30px;
  z-index: 100;
}

.switch-icon image {
  width: 100%;
  height: 100%;
}

/* 删除提示框样式 */
.delete-prompt {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: white;
  border-radius: 10px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  padding: 20px;
  z-index: 1000;
}

.prompt-content {
  text-align: center;
}

.delete-icon {
  width: 50px; /* 可根据需要调整图标大小 */
  height: 50px;
  margin-bottom: 10px;
}

.prompt-buttons {
  display: flex;
  justify-content: center;
  gap: 10px;
}

.prompt-button {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20px;
  cursor: pointer;
}    