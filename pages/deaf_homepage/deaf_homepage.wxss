/* 页面容器 */
.page-container {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8eb 0%, #fff5e6 100%);
  overflow: hidden;
}

/* 背景装饰 */
.page-container::before {
  content: '';
  position: fixed;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.page-container::after {
  content: '';
  position: fixed;
  bottom: -100rpx;
  left: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(244, 114, 182, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* 头部区域 */
.header {
  position: relative;
  padding: 60rpx 30rpx 20rpx;
  z-index: 10;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.2);
}

.app-title {
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-weight: 700;
  font-size: 40rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}

/* 主容器 */
.container {
  position: relative;
  padding: 0 30rpx 180rpx;
  z-index: 1;
}

/* 快捷按钮区域 */
.quick-actions {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin: 40rpx 0;
}

.action-card {
  width: 200rpx;
  height: 200rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
}

.action-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 100%);
  border-radius: inherit;
}

.action-card:active {
  transform: scale(0.95);
}

/* 相机按钮 - 紫色渐变 */
.action-card.camera {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow:
    0 12rpx 32rpx rgba(102, 126, 234, 0.3),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
}

.action-card.camera:active {
  box-shadow:
    0 6rpx 16rpx rgba(102, 126, 234, 0.3),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
}

/* 文字按钮 - 粉色渐变 */
.action-card.text {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  box-shadow:
    0 12rpx 32rpx rgba(250, 112, 154, 0.3),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
}

.action-card.text:active {
  box-shadow:
    0 6rpx 16rpx rgba(250, 112, 154, 0.3),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  filter: brightness(0) invert(1);
  z-index: 1;
}

.action-label {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
  z-index: 1;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

/* 常用语卡片 - 玻璃拟态 */
.phrase-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.08),
    0 8rpx 20rpx rgba(0, 0, 0, 0.04),
    inset 0 2rpx 0 rgba(255,255,255,0.8);
  padding: 40rpx;
  min-height: 800rpx;
  animation: slideInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  letter-spacing: 2rpx;
}

.card-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #6366f1 0%, #ec4899 100%);
  border-radius: 3rpx;
  margin-right: 16rpx;
  vertical-align: middle;
}

.card-count {
  font-size: 24rpx;
  color: #9ca3af;
  background: rgba(0,0,0,0.04);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* GIF 列表容器 */
.gif-scroll-container {
  max-height: 700rpx;
  overflow-y: auto;
}

.gif-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.gif-row {
  display: flex;
  gap: 24rpx;
}

/* GIF 卡片 */
.gif-item {
  flex: 1;
  aspect-ratio: 4/3.2;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 4rpx 12rpx rgba(0,0,0,0.05),
    0 1rpx 3rpx rgba(0,0,0,0.02);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  animation: cardEnter 0.5s cubic-bezier(0.16, 1, 0.3, 1) backwards;
}

.gif-item:nth-child(1) { animation-delay: 0.1s; }
.gif-item:nth-child(2) { animation-delay: 0.15s; }
.gif-item:nth-child(3) { animation-delay: 0.2s; }
.gif-item:nth-child(4) { animation-delay: 0.25s; }

@keyframes cardEnter {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.gif-item:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.gif-item image {
  width: 100%;
  height: calc(100% - 56rpx);
  object-fit: cover;
}

.gif-item .time {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 56rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.95) 30%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #4b5563;
  padding: 0 16rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 添加按钮 */
.gif-item.add-btn {
  background: rgba(255, 255, 255, 0.5);
  border: 2rpx dashed rgba(99, 102, 241, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.gif-item.add-btn:active {
  background: rgba(99, 102, 241, 0.05);
  border-color: rgba(99, 102, 241, 0.5);
}

.plus-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.4;
}

/* 占位符 */
.gif-item.placeholder {
  background: transparent;
  box-shadow: none;
}

/* 删除提示框 - 玻璃拟态 */
.delete-prompt {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx;
  padding: 48rpx 64rpx;
  box-shadow:
    0 24rpx 80rpx rgba(0, 0, 0, 0.15),
    0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
  animation: promptEnter 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes promptEnter {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.prompt-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #4b5563;
  margin-bottom: 8rpx;
}

.delete-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.6;
}

.prompt-buttons {
  display: flex;
  gap: 40rpx;
}

.prompt-button {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.prompt-button.confirm {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.prompt-button.confirm:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.prompt-button.cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.prompt-button.cancel:active {
  transform: scale(0.92);
  background: #e5e7eb;
}

/* 遮罩层 */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 999;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 旧样式兼容 */
.camera-button-wrapper {
  display: none;
}

.switch-icon {
  display: none;
}
