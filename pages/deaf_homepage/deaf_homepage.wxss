/* 页面 */
.page {
  min-height: 100vh;
  background: #fff;
  padding: 48rpx 32rpx;
  padding-bottom: 180rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a2e;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 主操作区 */
.actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 64rpx;
}

.action-btn {
  flex: 1;
  height: 180rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.action-btn.primary {
  background: #1a1a2e;
}

.action-btn.secondary {
  background: #f5f5f5;
}

.action-btn image {
  width: 56rpx;
  height: 56rpx;
}

.action-btn.primary image {
  filter: brightness(0) invert(1);
}

.action-btn text {
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary text {
  color: #fff;
}

.action-btn.secondary text {
  color: #1a1a2e;
}

/* 区域标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 常用语列表 */
.phrase-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.phrase-row {
  display: flex;
  gap: 24rpx;
}

.phrase-item {
  flex: 1;
  aspect-ratio: 4/3;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.phrase-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.phrase-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 添加按钮 */
.phrase-item.add {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 2rpx dashed #ddd;
}

.add-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1a1a2e;
  color: #fff;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空占位 */
.phrase-item.empty {
  background: transparent;
}

/* 弹窗 */
.modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
}

.modal-content {
  position: relative;
  width: 520rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx;
  z-index: 1;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 48rpx;
  color: #1a1a2e;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #666;
}

.modal-btn.danger {
  background: #e74c3c;
  color: #fff;
}

/* 按压反馈 */
.press:active {
  opacity: 0.7;
}
