<view class="page-container">
  <!-- 头部 Logo 区域 -->
  <view class="header">
    <view class="logo-section">
      <image src="/images/logo.png" mode="aspectFill" class="logo-image"></image>
      <view>
        <view class="app-title">心语者</view>
        <view class="app-subtitle">手语翻译助手</view>
      </view>
    </view>
  </view>

  <!-- 主容器 -->
  <view class="container">
    <!-- 快捷操作按钮 -->
    <view class="quick-actions">
      <view class="action-card camera" bindtap="openCamera">
        <image src="/images/camera_all_white.svg" mode="aspectFit" class="action-icon"></image>
        <text class="action-label">拍摄翻译</text>
      </view>
      <view class="action-card text" bindtap="openText">
        <image src="/images/text.png" mode="aspectFit" class="action-icon"></image>
        <text class="action-label">文字转视频</text>
      </view>
    </view>

    <!-- 常用语卡片 -->
    <view class="phrase-card">
      <view class="card-header">
        <text class="card-title">常用语</text>
        <text class="card-count">{{gifList.length || 0}} 条</text>
      </view>

      <view class="gif-scroll-container">
        <view class="gif-container">
          <block wx:for="{{chunkedGifList}}" wx:key="*this">
            <view class="gif-row">
              <!-- 第一个位置 -->
              <block wx:if="{{item[0]}}">
                <view class="gif-item card-stagger" bindlongpress="showDeletePrompt" data-index="{{index * 2}}">
                  <image src="{{item[0].thumbPath}}" mode="aspectFill" bindtap="previewGif" data-videoPath="{{item[0].videoPath}}"></image>
                  <view class="time">{{item[0].translationResult}}</view>
                </view>
              </block>
              <block wx:else>
                <view class="gif-item add-btn" bindtap="chooseVideo">
                  <image src="/images/plus_icon.svg" mode="aspectFit" class="plus-icon"></image>
                </view>
              </block>

              <!-- 第二个位置 -->
              <block wx:if="{{item[1]}}">
                <view class="gif-item card-stagger" bindlongpress="showDeletePrompt" data-index="{{index * 2 + 1}}">
                  <image src="{{item[1].thumbPath}}" mode="aspectFill" bindtap="previewGif" data-videoPath="{{item[1].videoPath}}"></image>
                  <view class="time">{{item[1].translationResult}}</view>
                </view>
              </block>
              <block wx:else>
                <view class="gif-item add-btn" wx:if="{{item[0]}}" bindtap="chooseVideo">
                  <image src="/images/plus_icon.svg" mode="aspectFit" class="plus-icon"></image>
                </view>
                <view class="gif-item placeholder" wx:else></view>
              </block>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 自定义导航栏 -->
  <custom-navbar is-deaf-mode="{{isDeafMode}}" bind:switchMode="handleSwitchMode"></custom-navbar>

  <!-- 删除确认弹窗 -->
  <view class="overlay" wx:if="{{showPrompt}}" bindtap="hideDeletePrompt"></view>
  <view class="delete-prompt" wx:if="{{showPrompt}}">
    <view class="prompt-content">
      <image src="/images/delete_icon.svg" mode="aspectFit" class="delete-icon"></image>
      <text class="prompt-text">确定要删除这条常用语吗？</text>
      <view class="prompt-buttons">
        <view class="prompt-button confirm" bindtap="deleteGif" data-confirm="true">✓</view>
        <view class="prompt-button cancel" bindtap="hideDeletePrompt">✕</view>
      </view>
    </view>
  </view>
</view>
