/* 基础样式 */
.container {
  width: 100vw;
  height: 100vh;
  background-color: #e6f0ff;
  position: relative;
  overflow: hidden;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  z-index: 100;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-btn image {
  width: 30rpx;
  height: 30rpx;
}

/* 滑动容器 - 关键修复 */
.swiper-container {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
}

.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 等比例白框 - 关键修复 */
.white-frame {
  width: calc(100vw - 50px); /* 左右两边各 20px，所以减去 40px */
  height: calc(100vh - 100px); /* 上下两边各 20px，所以减去 40px */
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  overflow: hidden;
  position: relative;
}

.content-image {
  width: 100%;
  height: 100%;
}