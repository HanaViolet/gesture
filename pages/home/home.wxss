.home-page {
  position: relative;
  padding-bottom: 40rpx;
}

.status-bar {
  width: 100%;
}

.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx 24rpx;
}

.header-left, .header-right {
  flex: 1;
  display: flex;
  align-items: center;
}

.header-left {
  gap: 16rpx;
}

.header-right {
  justify-content: flex-end;
}

.brand {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-right: 8rpx;
}

.header-link {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.7);
  box-shadow: 0 2rpx 8rpx rgba(0,122,255,0.06);
}

.home-body {
  padding: 0 32rpx;
  transition: opacity 180ms ease;
}

.fade-in {
  opacity: 1;
}

.fade-out {
  opacity: 0;
}

/* ===== 健听人模式：翻译舱 ===== */
.normal-main {
  width: 100%;
  height: 520rpx;
  margin-top: 16rpx;
  padding: 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  position: relative;
}

.normal-main-hint {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.normal-main-sub {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.normal-textarea {
  flex: 1;
  width: 100%;
  margin-top: 24rpx;
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.6;
  background: transparent;
}

.normal-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 24rpx;
}

.generate-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.normal-secondary {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.secondary-card {
  flex: 1;
  height: 200rpx;
  background: var(--surface);
  border-radius: var(--radius);
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 24rpx rgba(0,122,255,0.06);
  position: relative;
  overflow: hidden;
}

.secondary-card .card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.secondary-card .card-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
}

.card-badge {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-badge {
  background: var(--primary-light);
}

.learn-badge {
  background: rgba(39,174,96,0.1);
}

.badge-icon {
  font-size: 32rpx;
}

/* ===== 听障人士模式：表达矩阵 ===== */
.deaf-voice-area {
  width: 100%;
  margin-top: 16rpx;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  align-items: stretch;
}

.deaf-textarea {
  flex: 1;
  min-height: 160rpx;
  font-size: 36rpx;
  color: var(--text);
  line-height: 1.5;
  font-weight: 500;
  background: transparent;
}

.deaf-play-btn-wrapper {
  position: relative;
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.deaf-play-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.play-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  line-height: 1;
}

.play-text {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.ripple-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0,122,255,0.2);
  animation: rippleExpand 600ms ease-out forwards;
  z-index: 1;
}

.ripple-ring.delay {
  animation-delay: 150ms;
}

@keyframes rippleExpand {
  0% { width: 120rpx; height: 120rpx; opacity: 0.6; }
  100% { width: 220rpx; height: 220rpx; opacity: 0; }
}

.deaf-phrases-section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.phrase-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.phrase-chip {
  padding: 18rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 120ms ease;
}

.phrase-chip.urgent {
  background: var(--urgent-bg);
  color: var(--urgent-text);
}

.phrase-chip.daily {
  background: var(--daily-bg);
  color: var(--daily-text);
}

.phrase-chip.biz {
  background: var(--biz-bg);
  color: var(--biz-text);
  border: 1rpx solid rgba(0,122,255,0.15);
}

.phrase-chip.add {
  background: #f0f0f0;
  color: #999;
  padding: 18rpx 28rpx;
}

.fab-camera {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--surface);
  box-shadow: 0 8rpx 32rpx rgba(0,122,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.fab-icon {
  font-size: 44rpx;
}

/* ===== 添加常用语弹窗 ===== */
.add-modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.35);
  z-index: 900;
  opacity: 0;
  animation: fadeIn 200ms ease forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

.add-modal {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100vw;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  z-index: 901;
  transform: translateY(100%);
  transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  box-sizing: border-box;
}

.add-modal.show {
  transform: translateY(0);
}

.add-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  text-align: center;
  margin-bottom: 32rpx;
}

.add-options {
  display: flex;
  gap: 24rpx;
  overflow: hidden;
}

.add-option {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  background: var(--bg);
  border-radius: var(--radius);
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,122,255,0.06);
  border: 1rpx solid rgba(0,122,255,0.08);
  box-sizing: border-box;
}

.add-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.add-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
}

.add-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.add-cancel {
  margin-top: 32rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--text);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
