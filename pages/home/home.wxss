.home-page {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  overflow: hidden;
}

.status-bar {
  flex-shrink: 0;
  width: 100%;
}

/* ===== 顶部栏：简洁现代 ===== */
.home-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(var(--space-3) + env(safe-area-inset-top)) var(--space-4) var(--space-4);
  background: linear-gradient(180deg, var(--bg-warm) 0%, transparent 100%);
}

.header-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-1);
}

.brand-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.brand-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-secondary);
  line-height: 1;
}

.header-center {
  flex: 1.5;
  display: flex;
  justify-content: center;
}

.header-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}

/* ===== 设置胶囊按钮 ===== */
.settings-capsule {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  height: 72rpx;
  padding: 0 var(--space-4);
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  transition: all var(--duration-fast) var(--ease-out);
}

.settings-capsule:active {
  background: var(--bg-tertiary);
  transform: scale(0.96);
}

.settings-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.settings-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ===== 胶囊模式切换器：超大柔和 ===== */
.mode-switcher {
  height: 84rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  padding: 6rpx;
  display: flex;
  position: relative;
  width: 340rpx;
}

.mode-option {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  color: var(--text-secondary);
  transition: all var(--duration-normal) var(--ease-spring);
  z-index: 1;
  font-weight: 500;
}

.mode-option.active {
  background: var(--bg-elevated);
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
  font-weight: 600;
}

/* ===== Swiper 容器 ===== */
.home-swiper {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.swiper-page {
  width: 100%;
  height: 100%;
}

.swiper-scroll {
  width: 100%;
  height: 100%;
}

.home-body-inner {
  padding: 0 var(--space-4) var(--space-6);
}

/* ===== 听障版：输出区域 ===== */
.deaf-output-area {
  padding: var(--space-3) 0;
}

.output-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  box-shadow: var(--shadow);
  min-height: 160rpx;
  border: 2rpx solid var(--bg-tertiary);
}

.output-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--space-3);
  display: block;
  font-weight: 500;
}

.output-text {
  font-size: var(--font-xl);
  line-height: 1.5;
  color: var(--text-muted);
  font-weight: 500;
}

.output-text.has-content {
  color: var(--text-primary);
}

/* ===== 听障版：输入区域 ===== */
.deaf-input-area {
  padding: var(--space-3) 0 var(--space-5);
}

.input-wrapper {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-4);
  border: 2rpx solid var(--bg-tertiary);
}

.deaf-input {
  font-size: var(--font-lg);
  height: 56rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.input-placeholder {
  color: var(--text-placeholder);
}

.input-actions {
  display: flex;
  gap: var(--space-4);
}

.action-btn {
  flex: 1;
  height: 180rpx;
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  font-size: var(--font-lg);
  font-weight: 600;
  box-shadow: var(--shadow);
  transition: all var(--duration-fast) var(--ease-out);
}

.action-btn:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.action-btn .btn-icon {
  width: 64rpx;
  height: 64rpx;
}

.camera-btn {
  background: var(--gradient-warm);
  color: #FFFFFF;
}

.tts-btn {
  background: var(--bg-elevated);
  color: var(--brand-primary);
  border: 2rpx solid var(--brand-light);
}

.tts-btn .btn-icon {
  filter: none;
}

/* ===== 听障版：历史记录 ===== */
.deaf-history-area {
  padding: var(--space-2) 0 var(--space-4);
}

.deaf-history-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  padding-left: var(--space-1);
}

.deaf-history-list {
  display: flex;
  gap: var(--space-3);
}

.deaf-history-item {
  flex: 1;
  min-width: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  transition: all var(--duration-fast) var(--ease-out);
}

.deaf-history-item.empty {
  background: transparent;
  box-shadow: none;
  border: 2rpx dashed var(--bg-tertiary);
}

.deaf-history-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow);
}

.deaf-history-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.deaf-history-actions {
  display: flex;
  gap: var(--space-2);
}

.deaf-history-btn {
  flex: 1;
  height: 56rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-1);
  transition: all var(--duration-fast);
}

.deaf-history-btn:active {
  background: var(--brand-light);
}

.deaf-history-btn text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.deaf-history-icon {
  width: 24rpx;
  height: 24rpx;
}

/* ===== 心理健康入口卡片 ===== */
.psychology-entry-section {
  padding: var(--space-2) 0 var(--space-4);
}

.psychology-entry-card {
  display: flex;
  align-items: center;
  background: var(--gradient-care);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  box-shadow: 0 8rpx 32rpx rgba(124, 166, 140, 0.25);
  transition: all var(--duration-fast) var(--ease-out);
}

.psychology-entry-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(124, 166, 140, 0.2);
}

.psychology-entry-icon {
  font-size: 56rpx;
  margin-right: var(--space-4);
}

.psychology-entry-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.psychology-entry-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #FFFFFF;
}

.psychology-entry-desc {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.85);
}

.psychology-entry-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

/* ===== 快捷短语区域 ===== */
.deaf-quick-phrases {
  padding: var(--space-3) 0;
}

.phrase-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
}

.phrase-grid .btn-capsule {
  width: 100%;
  height: 100rpx;
  font-size: var(--font-md);
  font-weight: 600;
}

/* 编辑模式样式 */
.phrase-grid .btn-capsule.editing {
  opacity: 0.85;
  animation: shake 0.5s ease-in-out infinite;
}

@keyframes shake {
  0%, 100% { transform: rotate(-1deg); }
  50% { transform: rotate(1deg); }
}

/* 添加短语按钮 */
.btn-add-phrase {
  background: var(--bg-secondary) !important;
  border: 2rpx dashed var(--text-muted);
  box-shadow: none !important;
}

.btn-add-phrase .btn-text {
  color: var(--text-secondary) !important;
  font-size: 48rpx;
  font-weight: 300;
}

/* 快捷短语编辑栏 */
.phrase-edit-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--space-4);
  padding: 0 var(--space-1);
}

.edit-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.edit-toggle-btn {
  padding: var(--space-2) var(--space-4);
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
  transition: all var(--duration-fast);
}

.edit-toggle-btn:active {
  background: var(--brand-light);
  color: var(--brand-primary);
}

/* ===== 普通版：主卡片 ===== */
.normal-main {
  margin: var(--space-2) 0 0;
  padding: var(--space-5);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
  border: 2rpx solid var(--bg-tertiary);
}

.normal-main-hint {
  font-weight: 600;
  color: var(--text-primary);
  font-size: var(--font-lg);
}

.normal-main-sub {
  margin-top: var(--space-1);
  color: var(--text-tertiary);
}

.normal-textarea {
  width: 100%;
  margin-top: var(--space-4);
  min-height: 160rpx;
  font-size: var(--font-lg);
  line-height: 1.6;
  color: var(--text-primary);
  font-weight: 500;
}

.normal-textarea::placeholder {
  color: var(--text-placeholder);
}

.normal-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: var(--space-4);
}

.btn-brand {
  background: var(--bg-elevated) !important;
  color: var(--text-primary) !important;
  border: 2rpx solid var(--brand-light);
  box-shadow: var(--shadow-sm);
  min-width: 280rpx;
}

.btn-brand text,
.btn-brand .btn-text {
  color: var(--text-primary) !important;
}

.btn-brand .btn-icon {
  filter: none;
  margin-right: var(--space-2);
}

.btn-brand:active {
  background: var(--bg-secondary) !important;
}

/* ===== 普通版：次级卡片 ===== */
.normal-secondary {
  display: flex;
  gap: var(--space-4);
  margin: var(--space-4) 0 0;
}

.secondary-card {
  flex: 1;
  min-height: 180rpx;
  position: relative;
  overflow: hidden;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-4) 72rpx var(--space-4) var(--space-4);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  display: flex;
  flex-direction: column;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-out);
}

.secondary-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow);
}

.secondary-card .card-title {
  font-weight: 600;
  font-size: var(--font-md);
  color: var(--text-primary);
}

.secondary-card .card-desc {
  margin-top: var(--space-1);
  line-height: 1.4;
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.card-badge {
  position: absolute;
  right: var(--space-3);
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.camera-badge {
  background: var(--brand-light);
}

.learn-badge {
  background: var(--care-green-light);
}

/* ===== 普通版：语音录制区域 ===== */
.normal-record-area {
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--space-4);
}

.record-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-5);
}

.voice-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: var(--gradient-voice);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg), 0 0 40rpx rgba(107, 142, 159, 0.2);
  transition: all var(--duration-normal) var(--ease-out);
  position: relative;
  overflow: hidden;
}

.voice-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.25), transparent 60%);
  border-radius: 50%;
}

.voice-btn.recording {
  animation: voicePulse 1.5s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% {
    box-shadow: var(--shadow-lg), 0 0 40rpx rgba(107, 142, 159, 0.2);
    transform: scale(1);
  }
  50% {
    box-shadow: var(--shadow-xl), 0 0 60rpx rgba(107, 142, 159, 0.35);
    transform: scale(1.03);
  }
}

.voice-btn:active {
  transform: scale(0.97);
}

.voice-icon {
  width: 64rpx;
  height: 64rpx;
  filter: brightness(0) invert(1);
  position: relative;
  z-index: 1;
}

.record-hint {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ===== 普通版：历史记录区域 ===== */
.normal-history-area {
  height: 280rpx;
  margin: var(--space-4) 0 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 2rpx solid var(--bg-secondary);
}

.history-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.history-subtitle {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.refresh-btn {
  padding: var(--space-1) var(--space-3);
  background: var(--brand-light);
  border-radius: var(--radius-full);
  transition: all var(--duration-fast);
}

.refresh-btn:active {
  background: var(--brand-soft);
}

.refresh-btn text {
  font-size: var(--font-xs);
  color: var(--brand-primary);
  font-weight: 500;
}

.task-section-title {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: var(--space-3) var(--space-5) var(--space-2);
  font-weight: 500;
}

.divider {
  height: 2rpx;
  background: var(--bg-secondary);
  margin: var(--space-3) var(--space-5);
}

.history-list {
  flex: 1;
  padding: var(--space-2) var(--space-4);
  height: 100%;
  overflow-y: auto;
}

.history-empty {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-5);
}

.history-empty text {
  font-size: var(--font-base);
  color: var(--text-muted);
  text-align: center;
}

.history-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  transition: all var(--duration-fast) var(--ease-out);
}

.history-item:active {
  background: var(--brand-light);
  transform: scale(0.99);
}

.history-content {
  flex: 1;
  min-width: 0;
}

.history-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  display: block;
}

.history-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: var(--space-1) var(--space-3);
}

.history-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

.history-action-text {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* ===== 普通版：底部功能按钮 ===== */
.normal-bottom-actions {
  display: flex;
  justify-content: space-around;
  padding: var(--space-4) 0;
  margin-top: var(--space-2);
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-5);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  transition: all var(--duration-fast) var(--ease-out);
}

.bottom-btn:active {
  transform: scale(0.97);
  box-shadow: var(--shadow);
}

.bottom-btn text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.bottom-btn .btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.psychology-btn {
  background: var(--gradient-care) !important;
  border: none !important;
  box-shadow: 0 4rpx 16rpx rgba(124, 166, 140, 0.3) !important;
}

.psychology-btn text {
  color: #FFFFFF !important;
}

.psychology-btn-icon {
  font-size: 40rpx;
  display: block;
}

/* ===== 弹窗样式 ===== */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(44, 62, 68, 0.5);
  z-index: 900;
  backdrop-filter: blur(4rpx);
}

.phrase-modal, .keyboard-modal {
  position: fixed;
  left: 50%;
  bottom: 0;
  width: 100vw;
  max-width: 750rpx;
  transform: translateX(-50%) translateY(100%);
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding: var(--space-6) var(--space-5) calc(var(--space-6) + env(safe-area-inset-bottom));
  z-index: 901;
  transition: transform var(--duration-normal) var(--ease-spring);
}

.phrase-modal.show, .keyboard-modal.show {
  transform: translateX(-50%) translateY(0);
}

.modal-title {
  font-size: var(--font-xl);
  font-weight: 600;
  text-align: center;
  margin-bottom: var(--space-5);
  color: var(--text-primary);
}

.phrase-list {
  max-height: 50vh;
  overflow-y: auto;
}

.phrase-item {
  padding: var(--space-4) 0;
  border-bottom: 2rpx solid var(--bg-secondary);
  font-size: var(--font-lg);
  color: var(--text-primary);
  text-align: center;
  font-weight: 500;
  transition: all var(--duration-fast);
}

.phrase-item:last-child {
  border-bottom: none;
}

.phrase-item:active {
  background: var(--bg-secondary);
  margin: 0 calc(-1 * var(--space-5));
  padding-left: var(--space-5);
  padding-right: var(--space-5);
}

.modal-close {
  margin-top: var(--space-5);
  width: 100%;
  height: 96rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 600;
  transition: all var(--duration-fast);
}

.modal-close:active {
  background: var(--bg-tertiary);
}

.keyboard-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  font-size: var(--font-lg);
  box-sizing: border-box;
  font-weight: 500;
}

.modal-actions {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-5);
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-lg);
  font-weight: 600;
  transition: all var(--duration-fast);
}

.modal-btn.cancel {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.modal-btn.cancel:active {
  background: var(--bg-tertiary);
}

.modal-btn.confirm {
  background: var(--gradient-primary);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
}

.modal-btn.confirm:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 159, 0.25);
}

/* ===== 添加自定义快捷短语弹窗 ===== */
.phrase-add-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  width: 80vw;
  max-width: 600rpx;
  transform: translate(-50%, -50%) scale(0.9);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-6) var(--space-5);
  z-index: 901;
  opacity: 0;
  transition: all var(--duration-normal) var(--ease-spring);
  box-shadow: var(--shadow-xl);
}

.phrase-add-modal.show {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}

.phrase-add-input {
  width: 100%;
  height: 96rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 0 var(--space-4);
  font-size: var(--font-lg);
  box-sizing: border-box;
  margin-bottom: var(--space-5);
  font-weight: 500;
}

.phrase-type-selector {
  margin-bottom: var(--space-5);
}

.type-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
  display: block;
  font-weight: 500;
}

.type-options {
  display: flex;
  gap: var(--space-3);
}

.type-option {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  font-size: var(--font-base);
  color: var(--text-secondary);
  transition: all var(--duration-fast) var(--ease-out);
  font-weight: 500;
}

.type-option.active {
  background: var(--brand-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-sm);
}

/* ===== SMPL 查看器全屏容器 ===== */
.viewer-fullscreen {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1000;
  background: var(--bg-primary);
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .phrase-grid .btn-capsule,
  .action-btn,
  .bottom-btn {
    border: 4rpx solid var(--text-primary);
  }

  .card,
  .output-card,
  .normal-main,
  .normal-history-area,
  .secondary-card {
    border: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .voice-btn,
  .btn-capsule,
  .card,
  .action-btn {
    transition: none;
    animation: none;
  }
}

@media (min-font-size: 32rpx) {
  .output-text {
    font-size: var(--font-2xl);
  }

  .phrase-grid .btn-capsule {
    font-size: var(--font-lg);
    height: 120rpx;
  }
}
