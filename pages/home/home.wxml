<view class="page-full home-page" style="{{fontStyleVars}}">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶部栏：胶囊模式切换 + 设置按钮 -->
  <view class="home-header">
    <view class="header-left">
      <text class="brand">语见</text>
    </view>
    <view class="header-center">
      <!-- 胶囊模式切换器 -->
      <view class="mode-switcher" bindtap="switchMode">
        <view class="mode-option {{mode === 'normal' ? 'active' : ''}}">
          <text>普通版</text>
        </view>
        <view class="mode-option {{mode === 'deaf' ? 'active' : ''}}">
          <text>听障版</text>
        </view>
      </view>
    </view>
    <view class="header-right">
      <view class="settings-capsule press" bindtap="navigateToSettings" aria-label="设置">
        <image src="/icons/setting.svg" class="settings-icon" mode="aspectFit"/>
        <text class="settings-text">设置</text>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="home-body {{contentVisible ? 'fade-in' : 'fade-out'}}">

    <!-- ===== 听障版 (mode === 'deaf') ===== -->
    <block wx:if="{{mode === 'deaf'}}">
      <!-- 当前输出显示区域 -->
      <view class="deaf-output-area">
        <view class="output-card">
          <text class="output-label">当前输出</text>
          <text class="output-text {{currentOutput ? 'has-content' : ''}}">{{currentOutput || '输入文字或拍摄手语后将显示在这里'}}</text>
        </view>
      </view>

      <!-- 历史记录区域（最近3条） -->
      <view class="deaf-history-area">
        <text class="deaf-history-title">最近使用（{{deafOutputHistory.length}}/3）</text>
        <view class="deaf-history-list">
          <block wx:for="{{[0, 1, 2]}}" wx:key="*this">
            <view class="deaf-history-item {{!deafOutputHistory[item] ? 'empty' : ''}}">
              <block wx:if="{{deafOutputHistory[item]}}">
                <text class="deaf-history-text">{{deafOutputHistory[item].text}}</text>
                <view class="deaf-history-actions">
                  <view class="deaf-history-btn" bindtap="playHistoryItem" data-index="{{item}}">
                    <image src="/icons/volume.svg" mode="aspectFit" class="deaf-history-icon"/>
                    <text>播放</text>
                  </view>
                </view>
              </block>
              <block wx:else>
                <text class="deaf-history-text" style="color: #ccc;">空</text>
              </block>
            </view>
          </block>
        </view>
      </view>

      <!-- 快捷短语按钮网格 - 莫兰迪胶囊按钮 -->
      <view class="deaf-quick-phrases">
        <view class="phrase-grid">
          <block wx:for="{{quickPhrases}}" wx:key="id">
            <button
              class="btn-capsule {{item.type === 'urgent' ? 'btn-urgent' : (item.type === 'biz' ? 'btn-biz' : 'btn-daily')}} press"
              bindtap="selectQuickPhrase"
              data-phrase="{{item.text}}"
              data-type="{{item.type}}"
              aria-label="{{item.text}}"
            >
              <text class="btn-text">{{item.text}}</text>
            </button>
          </block>
        </view>
      </view>

      <!-- 输入框区域 + 相机按钮 -->
      <view class="deaf-input-area">
        <view class="input-wrapper">
          <input
            class="deaf-input"
            placeholder="输入文字或点击相机拍摄手语..."
            placeholder-class="input-placeholder"
            value="{{inputText}}"
            bindinput="onInputChange"
            maxlength="200"
            aria-label="输入文字"
          />
        </view>
        <view class="input-actions">
          <button class="action-btn camera-btn press" bindtap="openCameraForDeaf" aria-label="拍摄手语">
            <image src="/icons/camera.svg" mode="aspectFit" class="btn-icon"/>
            <text>拍摄</text>
          </button>
          <button class="action-btn tts-btn press {{rippleActive ? 'ripple' : ''}}" bindtap="playDeafTTS" aria-label="播放语音">
            <image src="/icons/volume.svg" mode="aspectFit" class="btn-icon"/>
            <text>播放</text>
          </button>
        </view>
      </view>
    </block>

    <!-- ===== 普通版 (mode === 'normal') ===== -->
    <block wx:if="{{mode === 'normal'}}">
      <!-- 文本输入 + 生成手语区域 -->
      <view class="normal-main card">
        <text class="text-secondary normal-main-hint">输入文字，生成手语动画</text>
        <text class="text-caption text-tertiary normal-main-sub">支持中文、英文、德文</text>
        <textarea
          class="normal-textarea"
          placeholder="{{texts.inputPlaceholder || '请输入要转换的文字...'}}"
          value="{{inputText}}"
          bindinput="onInputChange"
          maxlength="200"
        />
        <view class="normal-actions">
          <button class="btn-capsule btn-brand press" bindtap="generateSignLanguage">
            <image src="/icons/hand.svg" mode="aspectFit" class="btn-icon"/>
            <text>生成手语</text>
          </button>
        </view>
      </view>

      <view class="normal-secondary">
        <view class="secondary-card card press" bindtap="openCamera">
          <text class="card-title text-body">手语识别</text>
          <text class="card-desc text-caption text-secondary">拍摄或上传手语视频</text>
          <view class="card-badge camera-badge">
            <image src="/icons/camera.svg" mode="aspectFit" class="icon-small"/>
          </view>
        </view>
        <view class="secondary-card card press" bindtap="openPopularization">
          <text class="card-title text-body">手语科普</text>
          <text class="card-desc text-caption text-secondary">了解手语文化知识</text>
          <view class="card-badge learn-badge">
            <image src="/icons/book.svg" mode="aspectFit" class="icon-small"/>
          </view>
        </view>
      </view>

      <!-- 正圆语音按钮区域 -->
      <view class="normal-record-area">
        <view class="record-wrapper">
          <button
            class="voice-btn {{isRecording ? 'recording' : ''}} press"
            bindtouchstart="startRecording"
            bindtouchend="stopRecording"
            aria-label="按住说话"
          >
            <image src="/icons/mic.svg" mode="aspectFit" class="voice-icon"/>
          </button>
          <text class="record-hint">{{isRecording ? '松开结束' : '按住说话，松开发送'}}</text>
        </view>
      </view>

      <!-- 最近使用记录区域（最近3次SMPL生成） -->
      <view class="normal-history-area">
        <view class="history-header">
          <text class="history-title">最近使用</text>
          <text class="history-subtitle">最多保存3条</text>
        </view>
        <scroll-view class="history-list" scroll-y="true">
          <block wx:if="{{smplHistory.length === 0}}">
            <view class="history-empty">
              <text>输入文字生成手语动画后，将显示在这里</text>
            </view>
          </block>
          <block wx:for="{{smplHistory}}" wx:key="id">
            <view class="history-item press" bindtap="viewHistoryItem" data-index="{{index}}">
              <view class="history-content">
                <text class="history-text">{{item.text}}</text>
                <text class="history-time">{{item.time}}</text>
              </view>
              <view class="history-action">
                <image src="/icons/hand.svg" mode="aspectFit" class="history-icon"/>
                <text class="history-action-text">查看</text>
              </view>
            </view>
          </block>
        </scroll-view>
      </view>

      <!-- 底部功能按钮 -->
      <view class="normal-bottom-actions">
        <button class="bottom-btn press" bindtap="showQuickPhrases" aria-label="常用语">
          <image src="/icons/message.svg" mode="aspectFit" class="btn-icon"/>
          <text>常用语</text>
        </button>
        <button class="bottom-btn press" bindtap="openKeyboard" aria-label="打字">
          <image src="/icons/keyboard.svg" mode="aspectFit" class="btn-icon"/>
          <text>打字</text>
        </button>
        <button class="bottom-btn press" bindtap="waveHand" aria-label="打招呼">
          <image src="/icons/hand.svg" mode="aspectFit" class="btn-icon"/>
          <text>打招呼</text>
        </button>
      </view>
    </block>

  </view>

  <!-- 常用语弹窗 -->
  <view class="modal-mask" wx:if="{{showPhraseModal}}" bindtap="hidePhraseModal"></view>
  <view class="phrase-modal {{showPhraseModal ? 'show' : ''}}" wx:if="{{showPhraseModal}}">
    <view class="modal-title">常用语</view>
    <view class="phrase-list">
      <block wx:for="{{quickPhrases}}" wx:key="*this">
        <view class="phrase-item press" bindtap="usePhrase" data-phrase="{{item}}">{{item}}</view>
      </block>
    </view>
    <button class="modal-close" bindtap="hidePhraseModal">关闭</button>
  </view>

  <!-- 键盘输入弹窗 -->
  <view class="modal-mask" wx:if="{{showKeyboardModal}}" bindtap="hideKeyboardModal"></view>
  <view class="keyboard-modal {{showKeyboardModal ? 'show' : ''}}" wx:if="{{showKeyboardModal}}">
    <view class="modal-title">输入文字</view>
    <textarea
      class="keyboard-textarea"
      placeholder="请输入内容..."
      value="{{keyboardInput}}"
      bindinput="onKeyboardInput"
      maxlength="200"
    />
    <view class="modal-actions">
      <button class="modal-btn cancel" bindtap="hideKeyboardModal">取消</button>
      <button class="modal-btn confirm" bindtap="sendKeyboardText">发送</button>
    </view>
  </view>

  <!-- SMPL 手语动画查看器 -->
  <view class="viewer-fullscreen" wx:if="{{showViewer}}">
    <smpl-viewer text="{{viewerText}}" bind:close="closeViewer" />
  </view>
</view>
