/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 60rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background-color: #fff;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background-color: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-icon {
  font-size: 60rpx;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-text {
  font-size: 24rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 26rpx;
  color: #999;
}

/* 区域标题 */
.section-title {
  font-size: 26rpx;
  color: #666;
  padding: 24rpx 32rpx 16rpx;
  font-weight: 500;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 96rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item-textarea {
  flex-direction: column;
  align-items: flex-start;
  padding-bottom: 20rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333;
  width: 140rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 48rpx;
  line-height: 48rpx;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  color: #333;
}

.form-value.placeholder {
  color: #999;
}

.arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: #333;
  margin-top: 16rpx;
  padding: 16rpx 0;
}

.textarea-counter {
  align-self: flex-end;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 按钮区域 */
.btn-section {
  padding: 48rpx 32rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  border: none;
}

.btn-save:active {
  opacity: 0.9;
}

.btn-save.loading {
  background: #ccc;
}

.btn-clear {
  width: 100%;
  height: 88rpx;
  background-color: transparent;
  border: 2rpx solid #ff4d4f;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #ff4d4f;
}

.btn-clear:active {
  background-color: rgba(255, 77, 79, 0.1);
}

/* 底部选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}

.picker-content.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.picker-list {
  max-height: 50vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item.active {
  background-color: #f8f9fa;
}

.picker-item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.picker-item-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.picker-item-check {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
}
