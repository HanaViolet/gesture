/* ===== 个人资料：简洁表单设计 ===== */

.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: var(--space-6);
}

/* ===== 头部 ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(var(--space-3) + env(safe-area-inset-top)) var(--space-5) var(--space-3);
  background: var(--bg-elevated);
  border-bottom: 2rpx solid var(--bg-tertiary);
  box-shadow: var(--shadow-xs);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  border-radius: 50%;
  transition: all var(--duration-fast);
}

.back-btn:active {
  background: var(--bg-tertiary);
}

.back-icon {
  font-size: 40rpx;
  color: var(--text-primary);
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.header-right {
  width: 64rpx;
}

/* ===== 头像区域 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-7) 0 var(--space-6);
  background: var(--bg-elevated);
  margin-bottom: var(--space-4);
  border-bottom: 2rpx solid var(--bg-tertiary);
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  border: 4rpx solid var(--bg-tertiary);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-icon {
  font-size: 72rpx;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 56rpx;
  background: rgba(44, 62, 68, 0.6);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-text {
  font-size: var(--font-sm);
  color: #fff;
  font-weight: 500;
}

.avatar-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ===== 区域标题 ===== */
.section-title {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  padding: var(--space-4) var(--space-5) var(--space-3);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* ===== 表单区域 ===== */
.form-section {
  background: var(--bg-elevated);
  margin: 0 var(--space-4) var(--space-4);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
  overflow: hidden;
}

.form-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 2rpx solid var(--bg-secondary);
  min-height: 96rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item-textarea {
  flex-direction: column;
  align-items: flex-start;
  padding-bottom: var(--space-3);
}

.form-label {
  font-size: var(--font-md);
  color: var(--text-primary);
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
  height: 48rpx;
  line-height: 48rpx;
  font-weight: 500;
}

.form-input::placeholder {
  color: var(--text-placeholder);
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.form-value.placeholder {
  color: var(--text-placeholder);
}

.arrow {
  font-size: var(--font-base);
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-top: var(--space-3);
  padding: var(--space-3) 0;
  font-weight: 500;
}

.form-textarea::placeholder {
  color: var(--text-placeholder);
}

.textarea-counter {
  align-self: flex-end;
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: var(--space-1);
}

/* ===== 按钮区域 ===== */
.btn-section {
  padding: var(--space-6) var(--space-5);
}

.btn-save {
  width: 100%;
  height: 100rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
  font-size: var(--font-lg);
  color: #fff;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
  transition: all var(--duration-fast);
}

.btn-save:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 159, 0.25);
}

.btn-save.loading {
  background: var(--text-muted);
  box-shadow: none;
}

.btn-clear {
  width: 100%;
  height: 96rpx;
  background: transparent;
  border: 2rpx solid #FF6B6B;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  color: #FF6B6B;
  font-weight: 600;
  transition: all var(--duration-fast);
}

.btn-clear:active {
  background: rgba(255, 107, 107, 0.1);
}

/* ===== 底部选择器 ===== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 68, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all var(--duration-normal) var(--ease-out);
  backdrop-filter: blur(4rpx);
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  transform: translateY(100%);
  transition: transform var(--duration-normal) var(--ease-spring);
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(44, 62, 68, 0.15);
}

.picker-content.show {
  transform: translateY(0);
}

/* 拖拽指示条 */
.picker-content::before {
  content: '';
  position: absolute;
  top: var(--space-2);
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: 4rpx;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-6) var(--space-5) var(--space-4);
  border-bottom: 2rpx solid var(--bg-secondary);
}

.picker-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.picker-close {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  padding: var(--space-2);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  border-radius: 50%;
  transition: all var(--duration-fast);
}

.picker-close:active {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

.picker-list {
  max-height: 50vh;
  overflow-y: auto;
  padding-top: var(--space-2);
}

.picker-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-5);
  border-bottom: 2rpx solid var(--bg-secondary);
  transition: background var(--duration-fast);
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item:active {
  background: var(--bg-secondary);
}

.picker-item.active {
  background: var(--brand-soft);
}

.picker-item-icon {
  font-size: 40rpx;
  margin-right: var(--space-3);
}

.picker-item-text {
  flex: 1;
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 500;
}

.picker-item-check {
  font-size: var(--font-lg);
  color: var(--brand-primary);
  font-weight: bold;
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .form-section {
    border: 4rpx solid var(--text-primary);
  }

  .form-item {
    border-bottom: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .picker-mask,
  .picker-content {
    transition: none;
  }
}
