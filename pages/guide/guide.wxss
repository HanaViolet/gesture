.guide-container {
  position: relative;
  width: 100%;
  height: 100vh;
  background-color: #333; /* 改为深灰色，使屏幕整体为灰色 */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 20px;
  box-sizing: border-box;
}

.spotlight {
  z-index: 1;
}

.guide-content {
  z-index: 2;
  color: white;
  text-align: left; /* 文字左对齐，在聚光灯旁边 */
  padding: 10px;
  background-color: rgba(0, 0, 0, 0.6); /* 添加背景色，使文字更易读 */
  border-radius: 5px;
}

.guide-text {
  font-size: 16px;
}

.next-step-button {
  z-index: 2;
  background-color: #007AFF;
  color: white;
  padding: 10px 20px;
  border-radius: 5px;
  font-size: 16px;
  margin-top: 20px;
}