<view class="container">
  <!-- 进度条 -->
  <progress style="position: relative; left: 0rpx; top: 258rpx" class="progress-bar" percent="{{progress}}" show-info="true" />

  <!-- 输入文字区域（占35%） -->
  <view class="input-section" style="position: relative; left: 0rpx; top: -170rpx; width: 668rpx; display: flex; box-sizing: border-box">
    <input 
      class="text-input"
      type="text" 
      bindinput="onTextInput" 
      value="{{inputText}}" 
      placeholder="请输入文字以生成手语视频" 
    />
    <button class="confirm-button" bindtap="confirmEdit">确认</button>
  </view>

  <!-- 视频展示区域（占65%） -->
  <view class="video-section" style="position: relative; left: 0rpx; top: -85rpx; width: 668rpx; display: flex; box-sizing: border-box; height: 916rpx">
    <view class="video-box" bindtap="playVideoPlaceholder" style="position: relative; left: 0rpx; top: 29rpx; height: 837rpx; display: flex; box-sizing: border-box">
      <image src="/images/play.svg" class="play-icon" />
    </view>
  </view>

  <!-- 自定义弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}">
    <view class="modal-content">
      <text class="modal-text">功能还在开发中，敬请期待！</text>
      <button class="modal-close-btn" bindtap="closeModal">关闭</button>
    </view>
  </view>
</view>
