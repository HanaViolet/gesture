.container {
  height: 100vh;
  background-color: #f0f8ff;
  display: flex;
  flex-direction: column;
}

.progress-bar {
  width: 100%;
  height: 6px;
  margin: 0;
  background-color: #e0e0e0;
}

.input-section {
  flex: 0 0 35%;
  padding: 20px;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.text-input {
  width: 100%;
  max-width: 600px;
  height: 50px;
  padding: 12px 16px;
  margin-bottom: 20px;
  font-size: 16px;
  border: 1px solid #ccc;
  border-radius: 12px;
  box-sizing: border-box;
}

.confirm-button {
  width: 100%;
  max-width: 600px;
  height: 45px;
  background: linear-gradient(135deg, #4a6cff, #6a8cff);
  color: #fff;
  font-size: 16px;
  border: none;
  border-radius: 12px;
  box-shadow: 0 4px 12px rgba(74, 108, 255, 0.3);
}

.video-section {
  flex: 1;
  background-color: #f9fafb;
  display: flex;
  justify-content: center;
  align-items: center;
}

.video-box {
  width: 90%;
  height: 90%;
  background-color: #000000;
  border: 4px solid #ffffff;
  border-radius: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.play-icon {
  width: 80px;
  height: 80px;
  opacity: 0.8;
}

/* 新增弹窗部分 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 70%;
  max-width: 400px;
  background: #ffffff;
  padding: 40px 30px;
  border-radius: 12px;
  text-align: center;
}

.modal-text {
  font-size: 18px;
  color: #333;
  margin-bottom: 40px;
}

.modal-close-btn {
  width: 100%;
  height: 35px;
  background: linear-gradient(135deg, #d9ddec, #bec1ca);
  color: #ffffff;
  border: none;
  border-radius: 8px;
  font-size: 16px;
}
