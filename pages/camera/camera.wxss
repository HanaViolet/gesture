/* ===== 相机页面：沉浸式现代设计 ===== */

/* 相机容器 */
.camera-container {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
}

/* 自定义导航栏 */
.camera-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 110;
}

.camera-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(var(--space-3) + env(safe-area-inset-top)) var(--space-4) var(--space-3);
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.nav-back:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.back-arrow {
  font-size: 36rpx;
  color: #fff;
}

.nav-title {
  font-size: var(--font-lg);
  color: #fff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.nav-placeholder {
  width: 80rpx;
}

/* 顶部栏 */
.top-bar {
  position: absolute;
  top: 200rpx;
  left: var(--space-5);
  right: var(--space-5);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}

/* 图标按钮 */
.btn-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn-icon:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.btn-icon image {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

/* 倒计时 */
.countdown {
  font-size: 56rpx;
  font-weight: 600;
  color: #fff;
  font-variant-numeric: tabular-nums;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.countdown.recording {
  color: #FF6B6B;
}

/* 相机 */
camera {
  width: 100%;
  height: 100%;
}

/* 底部栏 */
.bottom-bar {
  position: absolute;
  bottom: 100rpx;
  left: var(--space-6);
  right: var(--space-6);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 圆形按钮 */
.btn-round {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn-round:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.btn-round.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.btn-round image {
  width: 44rpx;
  height: 44rpx;
  filter: brightness(0) invert(1);
}

/* 录制按钮 */
.record-wrapper {
  position: relative;
  padding: var(--space-2);
}

.record-wrapper.recording::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid #FF6B6B;
  animation: pulse 1.5s ease-out infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.4); opacity: 0; }
}

.record-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.record-inner {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #FF6B6B;
  transition: all var(--duration-fast);
}

.record-inner.stop {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  background: #FF6B6B;
}

/* 视频预览 */
#recordedVideo {
  position: absolute;
  inset: 0;
  z-index: 200;
  background: #000;
}

/* ===== 无障碍样式 ===== */
@media (prefers-reduced-motion: reduce) {
  .record-wrapper.recording::before {
    animation: none;
  }

  .btn-icon,
  .btn-round,
  .nav-back {
    transition: none;
  }
}
