/* 相机容器 */
.camera-container {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
}

/* 顶部栏 */
.top-bar {
  position: absolute;
  top: 60rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}

/* 图标按钮 */
.btn-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 200ms;
}

.btn-icon:active {
  background: rgba(255,255,255,0.25);
}

.btn-icon image {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

/* 倒计时 */
.countdown {
  font-size: 48rpx;
  font-weight: 500;
  color: #fff;
  font-variant-numeric: tabular-nums;
  letter-spacing: 4rpx;
}

.countdown.recording {
  color: #e74c3c;
}

/* 相机 */
camera {
  width: 100%;
  height: 100%;
}

/* 底部栏 */
.bottom-bar {
  position: absolute;
  bottom: 80rpx;
  left: 64rpx;
  right: 64rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
}

/* 圆形按钮 */
.btn-round {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 200ms;
}

.btn-round:active {
  background: rgba(255,255,255,0.25);
}

.btn-round.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.btn-round image {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

/* 录制按钮 */
.record-wrapper {
  position: relative;
  padding: 16rpx;
}

.record-wrapper.recording::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid #e74c3c;
  animation: pulse 1.5s ease-out infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.4); opacity: 0; }
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-inner {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e74c3c;
  transition: all 200ms;
}

.record-inner.stop {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: #e74c3c;
}

/* 视频预览 */
#recordedVideo {
  position: absolute;
  inset: 0;
  z-index: 200;
  background: #000;
}
