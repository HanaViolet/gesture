<!-- 心理健康AI对话页面 -->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <text class="nav-title">{{texts.title}}</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 对话区 -->
  <scroll-view
    class="chat-area"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    bounces
  >
    <view class="chat-list">

      <!-- 欢迎气泡 -->
      <view class="msg-group ai-group" wx:if="{{messages.length === 0}}">
        <image class="ai-avatar" src="/images/logo.png" mode="aspectFill"/>
        <view class="msg-col">
          <view class="bubble ai-bubble">
            <text class="bubble-text">{{texts.welcomeMessage}}🌿</text>
          </view>
          <view class="sign-chip-row">
            <view class="sign-chip" bindtap="onShowSign" data-text="{{texts.welcomeMessage}}">
              <text class="sign-chip-emoji">🤟</text>
              <text class="sign-chip-text">{{texts.viewSign}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 消息列表 -->
      <block wx:for="{{messages}}" wx:key="id">

        <!-- AI 消息 -->
        <view wx:if="{{item.role === 'ai'}}" class="msg-group ai-group" id="msg-{{item.id}}">
          <image class="ai-avatar" src="/images/logo.png" mode="aspectFill"/>
          <view class="msg-col">
            <view class="bubble ai-bubble">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <view class="sign-chip-row">
              <view class="sign-chip" bindtap="onShowSign" data-text="{{item.content}}">
                <text class="sign-chip-emoji">🤟</text>
                <text class="sign-chip-text">{{texts.viewSign}}</text>
              </view>
              <text class="msg-time">{{item.time}}</text>
            </view>
          </view>
        </view>

        <!-- 用户消息 -->
        <view wx:if="{{item.role === 'user'}}" class="msg-group user-group" id="msg-{{item.id}}">
          <view class="msg-col user-col">
            <view class="bubble user-bubble">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <text class="msg-time time-right">{{item.time}}</text>
          </view>
        </view>

      </block>

      <!-- AI 正在输入 -->
      <view class="msg-group ai-group" wx:if="{{aiTyping}}">
        <image class="ai-avatar" src="/images/logo.png" mode="aspectFill"/>
        <view class="bubble ai-bubble typing-bubble">
          <view class="typing-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>

  <!-- 摄像头区 -->
  <view class="camera-area">
    <camera
      wx:if="{{cameraOn}}"
      class="camera-view"
      device-position="front"
      flash="off"
      binderror="onCameraError"
    >
      <cover-view class="camera-overlay">
        <!-- 录制中状态 -->
        <cover-view wx:if="{{recording}}">
          <cover-view class="record-badge is-recording">
            <cover-view class="record-dot"></cover-view>
            <cover-view class="record-text">{{texts.recognizing}}</cover-view>
          </cover-view>
        </cover-view>
        <!-- 未录制：显示确认开始按钮 -->
        <cover-view wx:else class="confirm-start-wrap">
          <cover-view class="confirm-start-btn" bindtap="onToggleRecording">
            <cover-view class="confirm-btn-icon">▶</cover-view>
            <cover-view class="confirm-btn-text">{{texts.confirmStart}}</cover-view>
          </cover-view>
        </cover-view>
        <!-- 识别结果 -->
        <cover-view class="recog-result" wx:if="{{recognizedText}}">
          <cover-view class="recog-label">{{texts.recognized}}</cover-view>
          <cover-view class="recog-text">{{recognizedText}}</cover-view>
        </cover-view>
      </cover-view>
    </camera>

    <!-- 摄像头未开启：占位 -->
    <view wx:else class="camera-placeholder" bindtap="onToggleRecording">
      <view class="camera-pulse-ring"></view>
      <text class="camera-icon">📹</text>
      <text class="camera-hint">{{texts.cameraHint}}</text>
    </view>
  </view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <view class="input-wrap">
      <input
        class="text-input"
        placeholder="{{texts.inputPlaceholder}}"
        placeholder-style="color:#B0BEC5"
        value="{{textInput}}"
        bindinput="onTextInput"
        confirm-type="send"
        bindconfirm="onSendText"
        adjust-position
      />
    </view>
    <button
      class="send-btn {{textInput ? 'send-active' : ''}}"
      bindtap="onSendText"
      disabled="{{!textInput}}"
    ><text style="line-height:normal">{{texts.send}}</text></button>
  </view>

  <!-- 手语浮层 -->
  <view class="sign-modal" wx:if="{{showSignModal}}" bindtap="onHideSign">
    <view class="sign-modal-box" catchtap="noop">
      <view class="sign-modal-header">
        <text class="sign-modal-title">{{texts.signModalTitle}}</text>
        <view class="sign-modal-close" bindtap="onHideSign">
          <text class="close-icon">✕</text>
        </view>
      </view>

      <!-- 视频播放区域 -->
      <view class="sign-video-container">
        <!-- 加载中状态 -->
        <view class="sign-loading" wx:if="{{signLoading}}">
          <view class="loading-ring">
            <view class="loading-circle"></view>
          </view>
          <text class="sign-loading-text">{{texts.signLoading}}</text>
          <text class="sign-loading-sub">{{texts.signLoadingWait}}</text>
        </view>

        <!-- 审核模式：图片展示 -->
        <image
          wx:elif="{{signResultType === 'image' && signVideoUrl}}"
          src="{{signVideoUrl}}"
          mode="aspectFit"
          class="sign-video-player"
        />

        <!-- 正常模式：视频播放器 -->
        <video
          wx:elif="{{signResultType === 'video' && signVideoUrl}}"
          id="signVideo"
          class="sign-video-player"
          src="{{signVideoUrl}}"
          autoplay="true"
          loop="true"
          muted="false"
          show-center-play-btn="true"
          show-play-btn="true"
          controls="true"
          object-fit="contain"
          binderror="onVideoError"
        />

        <!-- 空状态 -->
        <view class="sign-empty" wx:else>
          <text class="sign-empty-icon">🤟</text>
          <text class="sign-empty-text">{{texts.signEmpty}}</text>
        </view>
      </view>

      <!-- 原文展示区域 -->
      <view class="sign-text-section">
        <view class="sign-text-label">{{texts.originalText}}</view>
        <scroll-view class="sign-text-content" scroll-y>
          <text class="sign-original-text">{{currentSignText}}</text>
        </scroll-view>
      </view>
    </view>
  </view>

</view>
