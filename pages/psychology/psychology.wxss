/* ===== 心理健康助手：温暖疗愈设计 ===== */

.page-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  overflow: hidden;
}

/* ===== 对话区 ===== */
.chat-area {
  flex: 1;
  min-height: 0;
}

.chat-list {
  padding: var(--space-4) var(--space-4) var(--space-3);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* 消息组：头像 + 内容列 */
.msg-group {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  animation: messageEnter var(--duration-normal) var(--ease-spring);
}

@keyframes messageEnter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ai-group {
  flex-direction: row;
}

.user-group {
  flex-direction: row-reverse;
}

/* AI 头像 */
.ai-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 3rpx solid var(--bg-elevated);
  box-shadow: var(--shadow-sm);
}

/* 内容列 */
.msg-col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-2);
  max-width: 72%;
}

.user-col {
  align-items: flex-end;
}

/* ===== 气泡 ===== */
.bubble {
  padding: var(--space-4);
  border-radius: var(--radius-xl);
  word-break: break-all;
}

/* AI气泡：白色卡片，左下角尖 */
.ai-bubble {
  background: var(--bg-elevated);
  border-bottom-left-radius: var(--space-1);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
}

/* 用户气泡：品牌渐变，右下角尖 */
.user-bubble {
  background: var(--gradient-primary);
  border-bottom-right-radius: var(--space-1);
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
}

.bubble-text {
  font-size: var(--font-md);
  line-height: 1.8;
  display: block;
  letter-spacing: 0.5rpx;
}

.ai-bubble .bubble-text {
  color: var(--text-primary);
}

.user-bubble .bubble-text {
  color: #FFFFFF;
}

/* ===== 手语 chip（气泡下方） ===== */
.sign-chip-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding-left: var(--space-1);
}

.sign-chip {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: var(--accent-light);
  border: 2rpx solid var(--accent-soft);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4) var(--space-2) var(--space-3);
  transition: all var(--duration-fast) var(--ease-out);
}

.sign-chip:active {
  background: var(--accent-soft);
  transform: scale(0.95);
}

.sign-chip-emoji {
  font-size: var(--font-lg);
  line-height: 1;
}

.sign-chip-text {
  font-size: var(--font-sm);
  color: var(--accent-dark);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* ===== 时间戳 ===== */
.msg-time {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.time-right {
  text-align: right;
}

/* ===== 输入中动画 ===== */
.typing-bubble {
  padding: var(--space-4) var(--space-5);
}

.typing-dots {
  display: flex;
  gap: var(--space-2);
  align-items: center;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--brand-secondary);
  animation: dotBounce 1.2s infinite ease-in-out;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
  30% { transform: translateY(-10rpx); opacity: 1; }
}

/* ===== 摄像头区 ===== */
.camera-area {
  flex-shrink: 0;
  height: 33vh;
  margin: 0 var(--space-4) var(--space-4);
  border-radius: var(--radius-xl);
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-md);
}

.camera-view {
  width: 100%;
  height: 100%;
}

.camera-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4);
}

/* 录制徽章 */
.record-badge {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: rgba(44, 62, 68, 0.6);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.record-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--text-muted);
}

.record-badge.is-recording .record-dot {
  background: #FF6B6B;
  animation: blink 0.9s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.1; }
}

.record-text {
  font-size: var(--font-base);
  color: #fff;
  font-weight: 500;
}

/* 识别结果 */
.recog-result {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  box-shadow: var(--shadow-sm);
}

.recog-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.recog-text {
  font-size: var(--font-md);
  color: var(--brand-primary);
  font-weight: 600;
}

/* 占位 */
.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  background: linear-gradient(145deg, var(--brand-soft) 0%, var(--care-green-soft) 100%);
  position: relative;
}

/* 脉冲动画圆环 */
.camera-pulse-ring {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(107, 142, 159, 0.25);
  animation: pulseRing 2s ease-out infinite;
}

@keyframes pulseRing {
  0% { transform: scale(0.7); opacity: 0.8; }
  100% { transform: scale(1.4); opacity: 0; }
}

.camera-icon {
  font-size: 88rpx;
  position: relative;
  z-index: 1;
}

.camera-hint {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ===== 底部输入栏 ===== */
.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  background: var(--bg-elevated);
  border-top: 2rpx solid var(--bg-tertiary);
  box-shadow: 0 -4rpx 16rpx rgba(44, 62, 68, 0.05);
}

.input-wrap {
  flex: 1;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--bg-tertiary);
  overflow: hidden;
  transition: all var(--duration-fast);
}

.input-wrap:focus-within {
  border-color: var(--brand-light);
  background: var(--bg-elevated);
  box-shadow: var(--shadow-sm);
}

.text-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-5);
  font-size: var(--font-md);
  color: var(--text-primary);
  box-sizing: border-box;
  background: transparent;
  font-weight: 500;
}

.text-input::placeholder {
  color: var(--text-placeholder);
}

.send-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 var(--space-5);
  background: var(--bg-tertiary);
  color: var(--text-muted);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 88rpx;
  transition: all var(--duration-fast) var(--ease-out);
}

.send-btn::after { border: none; }

.send-btn.send-active {
  background: var(--gradient-primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.4);
}

.send-btn:active { transform: scale(0.95); }

/* ===== 手语浮层 ===== */
.sign-modal {
  position: fixed;
  inset: 0;
  background: rgba(44, 62, 68, 0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
  backdrop-filter: blur(4rpx);
}

.sign-modal-box {
  width: 100%;
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(44, 62, 68, 0.2);
  animation: slideUp var(--duration-normal) var(--ease-spring);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.sign-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5) var(--space-5) var(--space-3);
  position: relative;
}

/* 顶部拖拽指示条 */
.sign-modal-header::before {
  content: '';
  position: absolute;
  top: var(--space-2);
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: 4rpx;
}

.sign-modal-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.sign-modal-close {
  width: 64rpx;
  height: 64rpx;
  background: var(--bg-secondary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
}

.sign-modal-close:active { background: var(--bg-tertiary); }

.close-icon {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: 1;
}

/* ===== 手语视频弹窗 - 优化版 ===== */
.sign-video-container {
  width: 100%;
  height: 680rpx;
  background: linear-gradient(145deg, #f5f7fa 0%, #e8ecf1 100%);
  position: relative;
  overflow: hidden;
}

/* 加载状态 */
.sign-loading {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
}

.loading-ring {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.loading-circle {
  width: 100%;
  height: 100%;
  border: 6rpx solid var(--bg-tertiary);
  border-top-color: var(--brand-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.sign-loading-text {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 600;
}

.sign-loading-sub {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* 视频播放器 */
.sign-video-player {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.sign-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
}

.sign-empty-icon {
  font-size: 80rpx;
}

.sign-empty-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

/* 原文展示区域 */
.sign-text-section {
  padding: var(--space-4) var(--space-5);
  background: var(--bg-elevated);
  border-top: 2rpx solid var(--bg-tertiary);
}

.sign-text-label {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-bottom: var(--space-2);
  font-weight: 500;
}

.sign-text-content {
  max-height: 180rpx;
}

.sign-original-text {
  font-size: var(--font-lg);
  color: var(--text-primary);
  line-height: 1.8;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 确认开始按钮（摄像头开启后显示） */
.confirm-start-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.confirm-start-btn {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  background: var(--gradient-primary);
  padding: var(--space-4) var(--space-6);
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: var(--shadow-md), var(--shadow-glow);
  transition: all var(--duration-fast);
}

.confirm-start-btn:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

.confirm-btn-icon {
  font-size: var(--font-lg);
  color: #fff;
  line-height: 1;
}

.confirm-btn-text {
  font-size: var(--font-md);
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .ai-bubble,
  .user-bubble {
    border: 4rpx solid var(--text-primary);
  }

  .sign-chip {
    border: 4rpx solid var(--accent-dark);
  }
}

@media (prefers-reduced-motion: reduce) {
  .msg-group,
  .dot,
  .camera-pulse-ring,
  .sign-spinner {
    animation: none;
  }
}
