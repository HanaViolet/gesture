.container {
  background: var(--bg-primary, #FAF9F7);
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.phrase-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--text-primary, #2D2D2D);
  text-align: left;
  padding-left: 8rpx;
  border-left: 6rpx solid var(--morandi-blue, #7A8B99);
}

.content-scroll {
  max-height: 400rpx;
  overflow-y: auto;
}

.small-block {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: var(--bg-secondary, #F2F0ED);
  border-radius: 16rpx;
  transition: all 200ms ease;
}

.small-block:active {
  background: var(--morandi-blue-light, #B8C4CE);
  transform: scale(0.98);
}

.small-block image {
  width: 120rpx;
  height: 90rpx;
  margin-right: 24rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.small-block text {
  font-size: 30rpx;
  color: var(--text-primary, #2D2D2D);
  font-weight: 500;
}

/* 论坛按钮 */
.community-button {
  width: 100%;
  margin-top: 16rpx;
  padding: 32rpx 0;
  background: var(--gradient-daily);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(122, 139, 153, 0.25);
  transition: all 200ms ease;
}

.community-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(122, 139, 153, 0.15);
}

/* 空状态提示 */
.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: var(--text-tertiary, #8A8A8A);
  font-size: 28rpx;
}
