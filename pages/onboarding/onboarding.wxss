/* ===== 引导页面：温暖欢迎设计 ===== */

.onboarding-page {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  padding: 0 var(--space-5);
  box-sizing: border-box;
}

/* ===== 状态栏占位 ===== */
.status-bar {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 欢迎区域 ===== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-7) 0 var(--space-6);
  animation: fadeSlideUp var(--duration-slow) var(--ease-out);
}

.welcome-icon {
  margin-bottom: var(--space-5);
}

.welcome-logo {
  width: 180rpx;
  height: 180rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.welcome-subtitle {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ===== 通用区块样式 ===== */
.section {
  margin-bottom: var(--space-6);
  animation: fadeSlideUp var(--duration-slow) var(--ease-out) 100ms backwards;
}

.section-header {
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.section-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: var(--space-1);
  display: block;
}

/* ===== 语言选择器 ===== */
.language-selector {
  display: flex;
  gap: var(--space-3);
}

.lang-option {
  flex: 1;
  position: relative;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid var(--bg-tertiary);
  transition: all var(--duration-fast) var(--ease-out);
  box-shadow: var(--shadow-xs);
}

.lang-option:active {
  transform: scale(0.98);
}

.lang-option.active {
  border-color: var(--brand-primary);
  background: var(--brand-soft);
  box-shadow: var(--shadow-sm);
}

.lang-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.lang-local {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.check-icon {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  width: 36rpx;
  height: 36rpx;
  background: var(--brand-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-dot {
  width: 14rpx;
  height: 14rpx;
  background: #fff;
  border-radius: 50%;
}

/* ===== 模式选择器 ===== */
.mode-selector {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.mode-card {
  display: flex;
  align-items: center;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  border: 2rpx solid var(--bg-tertiary);
  transition: all var(--duration-fast) var(--ease-out);
  box-shadow: var(--shadow-xs);
}

.mode-card:active {
  transform: scale(0.99);
}

.mode-card.active {
  border-color: var(--brand-primary);
  background: var(--brand-soft);
  box-shadow: var(--shadow-sm);
}

.mode-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--space-4);
  background: var(--bg-secondary);
}

.mode-icon {
  width: 56rpx;
  height: 56rpx;
}

.mode-content {
  flex: 1;
  min-width: 0;
}

.mode-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.mode-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-1);
  display: block;
  line-height: 1.5;
}

.mode-check {
  margin-left: var(--space-3);
}

.check-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
}

.check-circle.checked {
  background: var(--brand-primary);
  border-color: var(--brand-primary);
}

.check-mark {
  width: 20rpx;
  height: 10rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg) translate(2rpx, -2rpx);
}

/* ===== 底部区域 ===== */
.footer-section {
  margin-top: auto;
  padding: var(--space-5) 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeSlideUp var(--duration-slow) var(--ease-out) 200ms backwards;
}

.enter-btn {
  width: 100%;
  height: 104rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md), var(--shadow-glow);
  transition: all var(--duration-fast) var(--ease-out);
}

.enter-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.enter-btn.disabled {
  background: var(--text-muted);
  box-shadow: none;
  opacity: 0.7;
}

.enter-btn .btn-text {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #FFFFFF !important;
}

.btn-text {
  color: #FFFFFF !important;
}

.footer-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: var(--space-3);
}

.safe-area {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 动画 ===== */
@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 无障碍样式 ===== */
@media (prefers-reduced-motion: reduce) {
  .welcome-section,
  .section,
  .footer-section {
    animation: none;
  }

  .lang-option,
  .mode-card,
  .enter-btn {
    transition: none;
  }
}

@media (prefers-contrast: high) {
  .lang-option,
  .mode-card {
    border-width: 4rpx;
  }

  .check-circle {
    border-width: 6rpx;
  }
}
