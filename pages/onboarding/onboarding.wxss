/* 引导页面样式 - 克制极简、温暖科技 */

.onboarding-page {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  padding: 0 var(--space-4);
  box-sizing: border-box;
}

/* ===== 状态栏占位 ===== */
.status-bar {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 欢迎区域 ===== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-6) 0 var(--space-5);
  animation: fadeSlideUp var(--duration-slow) var(--ease-out);
}

.welcome-icon {
  margin-bottom: var(--space-4);
}

.icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--brand) 0%, var(--accent) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
}

.icon-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.welcome-subtitle {
  font-size: var(--font-caption);
  color: var(--text-secondary);
}

/* ===== 通用区块样式 ===== */
.section {
  margin-bottom: var(--space-5);
  animation: fadeSlideUp var(--duration-slow) var(--ease-out) 100ms backwards;
}

.section-header {
  margin-bottom: var(--space-3);
}

.section-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.section-desc {
  font-size: var(--font-caption);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  display: block;
}

/* ===== 语言选择器 ===== */
.language-selector {
  display: flex;
  gap: var(--space-2);
}

.lang-option {
  flex: 1;
  position: relative;
  background: var(--bg-elevated);
  border-radius: var(--radius);
  padding: var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all var(--duration-normal);
}

.lang-option:active {
  transform: scale(0.98);
}

.lang-option.active {
  border-color: var(--brand);
  background: var(--brand-light);
  box-shadow: var(--shadow-sm);
}

.lang-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.lang-local {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--brand);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-dot {
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 50%;
}

/* ===== 模式选择器 ===== */
.mode-selector {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.mode-card {
  display: flex;
  align-items: center;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 2rpx solid transparent;
  transition: all var(--duration-normal);
}

.mode-card:active {
  transform: scale(0.99);
}

.mode-card.active {
  border-color: var(--brand);
  background: var(--brand-light);
  box-shadow: var(--shadow-md);
}

.mode-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--space-3);
}

.mode-icon {
  width: 56rpx;
  height: 56rpx;
}

.mode-content {
  flex: 1;
  min-width: 0;
}

.mode-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.mode-desc {
  font-size: var(--font-caption);
  color: var(--text-secondary);
  margin-top: 4rpx;
  display: block;
  line-height: 1.4;
}

.mode-check {
  margin-left: var(--space-3);
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-normal);
}

.check-circle.checked {
  background: var(--brand);
  border-color: var(--brand);
}

.check-mark {
  width: 20rpx;
  height: 10rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg) translate(2rpx, -2rpx);
}

/* ===== 底部区域 ===== */
.footer-section {
  margin-top: auto;
  padding: var(--space-4) 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeSlideUp var(--duration-slow) var(--ease-out) 200ms backwards;
}

.enter-btn {
  width: 100%;
  height: 96rpx;
  background: var(--brand);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  transition: all var(--duration-normal);
}

.enter-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
  opacity: 0.9;
}

.enter-btn.disabled {
  background: var(--text-tertiary);
  opacity: 0.5;
  box-shadow: none;
}

.btn-text {
  font-size: var(--font-body);
  font-weight: 600;
  color: #fff;
}

.footer-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-3);
}

.safe-area {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 动画 ===== */
@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 无障碍：减少动画 ===== */
@media (prefers-reduced-motion: reduce) {
  .welcome-section,
  .section,
  .footer-section {
    animation: none;
  }

  .lang-option,
  .mode-card,
  .enter-btn {
    transition: none;
  }
}

/* ===== 高对比度模式 ===== */
@media (prefers-contrast: high) {
  .lang-option.active,
  .mode-card.active {
    border-width: 4rpx;
  }

  .check-circle {
    border-width: 6rpx;
  }
}
