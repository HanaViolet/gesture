/* ===== 手语教学：沉浸式学习设计 ===== */

.container {
  width: 100vw;
  height: 100vh;
  background: var(--bg-primary);
  position: relative;
  overflow: hidden;
}

.back-btn {
  position: absolute;
  top: calc(60rpx + env(safe-area-inset-top));
  left: var(--space-4);
  z-index: 100;
  width: 72rpx;
  height: 72rpx;
  background: var(--bg-elevated);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--bg-tertiary);
}

.back-btn:active {
  background: var(--bg-secondary);
}

.back-btn image {
  width: 36rpx;
  height: 36rpx;
}

.swiper-container {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
}

.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.white-frame {
  width: calc(100vw - var(--space-6));
  height: calc(100vh - 140rpx);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--bg-tertiary);
  overflow: hidden;
  position: relative;
}

.content-image {
  width: 100%;
  height: 100%;
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .white-frame {
    border: 4rpx solid var(--text-primary);
  }
}
