/**app.wxss**/

/* ===== 莫兰迪色系设计系统：克制高级感、温暖无障碍 ===== */
page {
  /* 莫兰迪背景层 - 暖灰调，提升高级感 */
  --bg-warm: #FAF9F7;           /* 极淡暖灰，替代纯白 */
  --bg-primary: var(--bg-warm);
  --bg-secondary: #F2F0ED;      /* 次级背景 */
  --bg-elevated: #FFFFFF;       /* 卡片表面 */
  --bg-card: #FFFFFF;

  /* 莫兰迪品牌色系 */
  --morandi-blue: #7A8B99;      /* 主品牌色 - 灰蓝 */
  --morandi-blue-light: #B8C4CE;/* 浅灰蓝 */
  --morandi-blue-dark: #5A6B79; /* 深灰蓝 */

  --morandi-amber: #D4A373;     /* 强调色 - 琥珀 */
  --morandi-amber-light: #E8D4B8;/* 浅琥珀 */
  --morandi-amber-dark: #B8935F;/* 深琥珀 */

  --morandi-gray: #9A9A9A;      /* 中性灰 */
  --morandi-gray-light: #C5C5C5;/* 浅灰 */

  /* 兼容性映射 */
  --brand: var(--morandi-blue);
  --brand-light: var(--morandi-blue-light);
  --brand-dark: var(--morandi-blue-dark);
  --accent: var(--morandi-amber);

  /* 功能渐变色 - 加深以提高对比度(WCAG AA) */
  --gradient-urgent: linear-gradient(135deg, #B8834F 0%, #A6703D 100%);
  --gradient-daily: linear-gradient(135deg, #5A6B7A 0%, #4A5B6A 100%);
  --gradient-biz: linear-gradient(135deg, #6A6A6A 0%, #5A5A5A 100%);
  --gradient-voice: linear-gradient(135deg, #5A6B7A 0%, #3A4B5A 100%);

  /* 文字色 */
  --text-primary: #2D2D2D;      /* 深灰，非纯黑 */
  --text-secondary: #5A5A5A;    /* 次级 */
  --text-tertiary: #8A8A8A;     /* 辅助 */
  --text-inverse: #FFFFFF;      /* 反白 */
  --text-muted: #AAAAAA;        /* 占位 */

  /* 听障模式专用 - 莫兰迪调 */
  --deaf-urgent: #C9956A;       /* 紧急 - 琥珀 */
  --deaf-daily: #7A8B99;        /* 日常 - 灰蓝 */
  --deaf-biz: #9A9A9A;          /* 业务 - 灰 */

  /* 间距 - 8rpx 基准 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --space-6: 64rpx;

  /* 圆角 - 更克制 */
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  /* 阴影 - 更克制的Elevation */
  --shadow-sm: 0 1rpx 3rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(91, 123, 163, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(91, 123, 163, 0.12);

  /* 动画 */
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 350ms;
  --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-in-out: cubic-bezier(0.45, 0, 0.55, 1);

  /* 字体系统 - 极致克制 */
  --font-display: 36rpx;        /* 页面标题，字重600 */
  --font-body: 30rpx;           /* 正文内容，字重400 */
  --font-caption: 24rpx;        /* 辅助说明，字重400 */

  /* 听障模式专用字号 */
  --font-deaf-body: 34rpx;      /* 大字号正文 */
  --font-deaf-display: 40rpx;   /* 大标题 */
  --leading-deaf: 1.8;          /* 宽松行高 */

  /* 兼容性映射（旧变量名） */
  --text-display: var(--font-display);
  --text-body: var(--font-body);
  --text-caption: var(--font-caption);
  --text-deaf-body: var(--font-deaf-body);
  --text-deaf-display: var(--font-deaf-display);

  /* 无障碍 */
  --touch-min: 88rpx;           /* 最小触摸区域 */
}

/* ===== 基础 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  background: var(--bg-primary);
  line-height: 1.6;
  min-height: 100vh;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ===== 边框卡片（克制版，替代阴影卡片） ===== */
.card {
  background: var(--bg-elevated);
  border-radius: var(--radius);
  border-bottom: 1rpx solid #F0F0F0;
  padding: var(--space-4);
  transition: transform var(--duration-normal), box-shadow var(--duration-normal);
}

.card-hover:active {
  box-shadow: var(--shadow-md);
  transform: translateY(-2rpx);
}

/* ===== 弥散阴影卡片（仅用于悬浮元素） ===== */
.card-shadow {
  background: var(--bg-elevated);
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
}

/* ===== 玻璃拟态（克制版） ===== */
.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-lg);
}

/* ===== 莫兰迪按钮系统 ===== */

/* 基础胶囊按钮 */
.btn-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;  /* 大圆角胶囊 */
  padding: 0 48rpx;
  font-size: var(--font-body);
  font-weight: 500;
  transition: all var(--duration-fast);
  border: none;
  color: #FFFFFF;
  white-space: nowrap;  /* 防止文字换行 */
  min-width: 200rpx;    /* 最小宽度 */
}

.btn-capsule text,
.btn-capsule .btn-text {
  color: #FFFFFF !important;
  white-space: nowrap;  /* 防止文字换行 */
}

.btn-capsule:active {
  transform: scale(0.96);
}

/* 紧急按钮 - 琥珀渐变 (加深版) */
.btn-urgent {
  background: var(--gradient-urgent);
  color: #FFFFFF !important;
  box-shadow: 0 4rpx 16rpx rgba(160, 110, 60, 0.35);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
  font-weight: 600;
}

.btn-urgent .btn-text {
  color: #FFFFFF !important;
}

.btn-urgent:active {
  box-shadow: 0 2rpx 8rpx rgba(160, 110, 60, 0.25);
}

/* 日常按钮 - 灰蓝渐变 (加深版) */
.btn-daily {
  background: var(--gradient-daily);
  color: #FFFFFF !important;
  box-shadow: 0 4rpx 16rpx rgba(70, 90, 110, 0.3);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
  font-weight: 600;
}

.btn-daily .btn-text {
  color: #FFFFFF !important;
}

.btn-daily:active {
  box-shadow: 0 2rpx 8rpx rgba(70, 90, 110, 0.2);
}

/* 业务按钮 - 中性灰 (加深版) */
.btn-biz {
  background: var(--gradient-biz);
  color: #FFFFFF !important;
  box-shadow: 0 4rpx 16rpx rgba(80, 80, 80, 0.3);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
  font-weight: 600;
}

.btn-biz .btn-text {
  color: #FFFFFF !important;
}

/* ===== 正圆语音按钮（普通版核心） ===== */
.voice-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;  /* 必须正圆 */
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-voice);
  box-shadow: 0 8rpx 32rpx rgba(122, 139, 153, 0.35);
  transition: all var(--duration-normal);
  position: relative;
  overflow: hidden;
}

.voice-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.2), transparent);
  border-radius: 50%;
}

.voice-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(122, 139, 153, 0.25);
}

/* 录音中动画 */
.voice-btn.recording {
  animation: voicePulse 1.5s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(122, 139, 153, 0.35); }
  50% { box-shadow: 0 8rpx 48rpx rgba(122, 139, 153, 0.55); }
}

/* ===== 胶囊模式切换器 ===== */
.mode-switcher {
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(122, 139, 153, 0.1);
  padding: 4rpx;
  display: flex;
  position: relative;
}

.mode-option {
  flex: 1;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--duration-normal);
  z-index: 1;
}

.mode-option.active {
  background: #fff;
  color: var(--text-primary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  font-weight: 500;
}

/* ===== 旧按钮系统（兼容性保留） ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3) var(--space-5);
  border-radius: 48rpx;
  font-size: var(--text-body);
  font-weight: 500;
  transition: all var(--duration-fast);
  min-height: 88rpx; /* WCAG触摸目标 */
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 主按钮 - 克制版 */
.btn-primary {
  background: var(--brand);
  color: #fff;
}

.btn-primary:active {
  background: rgba(91, 123, 163, 0.9);
}

/* 次级按钮 */
.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border: 1rpx solid #E5E5E5;
}

.btn-secondary:active {
  background: var(--bg-secondary);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--brand);
  padding: var(--space-2) var(--space-3);
  min-height: auto;
}

/* 听障模式大按钮 */
.btn-deaf {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  font-size: var(--text-deaf-body);
  min-height: 140rpx;
}

/* ===== 输入框（去边框设计） ===== */
.input-minimal {
  border: none;
  border-bottom: 1rpx solid #E5E5E5;
  border-radius: 0;
  padding: var(--space-3) 0;
  font-size: var(--text-body);
  color: var(--text-primary);
  background: transparent;
  transition: border-color var(--duration-normal);
  width: 100%;
}

.input-minimal:focus {
  border-bottom-color: var(--brand);
}

.input-minimal::placeholder {
  color: var(--text-muted);
}

/* 听障模式大输入框 */
.input-deaf {
  font-size: var(--text-deaf-body);
  line-height: var(--leading-deaf);
  min-height: 160rpx;
}

/* ===== 标签/芯片 ===== */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 18rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: transform var(--duration-fast);
}

.chip:active {
  transform: scale(0.96);
}

.chip-urgent {
  background: var(--deaf-urgent);
  color: #fff;
}

.chip-daily {
  background: var(--deaf-daily);
  color: var(--deaf-urgent);
}

.chip-biz {
  background: var(--deaf-biz);
  color: var(--brand);
  border: 1rpx solid rgba(91, 123, 163, 0.15);
}

.chip-add {
  background: #f0f0f0;
  color: var(--text-tertiary);
}

/* ===== 图标规范 ===== */
.icon {
  width: 48rpx;
  height: 48rpx;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.icon-large {
  width: 64rpx;
  height: 64rpx;
}

.icon-small {
  width: 36rpx;
  height: 36rpx;
}

/* ===== 文字工具类 ===== */
.text-display { font-size: var(--font-display); font-weight: 600; line-height: 1.4; }
.text-body { font-size: var(--font-body); line-height: 1.6; }
.text-caption { font-size: var(--font-caption); color: var(--text-secondary); }
.text-tertiary { font-size: var(--font-caption); color: var(--text-tertiary); }

/* 听障模式文字 */
.text-deaf-display { font-size: var(--font-deaf-display); font-weight: 600; line-height: 1.4; }
.text-deaf-body { font-size: var(--font-deaf-body); line-height: var(--leading-deaf); }

/* ===== 全屏容器 ===== */
.page-full {
  min-height: 100vh;
  background: var(--bg-primary);
  box-sizing: border-box;
  overflow: hidden;
  padding: var(--space-4);
}

/* ===== 页面转场动画 ===== */
.page-enter {
  animation: fadeSlideUp var(--duration-slow) ease-out;
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.page-exit {
  animation: fadeSlideDown var(--duration-normal) ease-in forwards;
}

@keyframes fadeSlideDown {
  to {
    opacity: 0;
    transform: translateY(10rpx);
  }
}

/* ===== 脉冲加载动画（克制版） ===== */
.loading-pulse {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}

.loading-pulse::before,
.loading-pulse::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--brand);
  opacity: 0.3;
  animation: subtlePulse 2s ease-in-out infinite;
}

.loading-pulse::after {
  animation-delay: 1s;
}

@keyframes subtlePulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.3;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.5;
  }
}

/* ===== 波纹效果（听障模式视觉反馈） ===== */
.ripple-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--brand);
  opacity: 0.4;
  animation: rippleExpand 800ms ease-out forwards;
}

@keyframes rippleExpand {
  to {
    transform: translate(-50%, -50%) scale(1.6);
    opacity: 0;
  }
}

/* ===== 按压反馈 ===== */
.press:active {
  opacity: 0.7;
  transform: scale(0.98);
  transition: all var(--duration-fast) ease;
}

/* ===== 弹性布局工具类 ===== */
.flex { display: flex; }
.flex-inline { display: inline-flex; }

.flex-row { flex-direction: row; }
.flex-col { flex-direction: column; }

.flex-wrap { flex-wrap: wrap; }
.flex-nowrap { flex-wrap: nowrap; }

.flex-1 { flex: 1; }
.flex-auto { flex: auto; }
.flex-none { flex: none; }

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-around {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.flex-start {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.flex-end {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
