/* ===== 安全区域适配 ===== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* ===== 响应式布局策略 ===== */

/* 基础响应式：使用流式布局 */
.container {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: var(--space-4);
  box-sizing: border-box;
}

/* 网格布局 */
.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--space-2));
}

.grid-item {
  flex: 0 0 calc(50% - var(--space-4));
  margin: var(--space-2);
}

/* 三列网格 */
.grid-3 {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--space-2));
}

.grid-3 .grid-item {
  flex: 0 0 calc(33.333% - var(--space-4));
  margin: var(--space-2);
}

/* 字体放大适配策略 */
@media (min-font-size: 150%) {
  page {
    --font-body: 32rpx;
    --font-display: 38rpx;
  }

  .grid-item,
  .grid-3 .grid-item {
    flex: 0 0 calc(100% - var(--space-4));
  }

  .card {
    padding: var(--space-5);
  }
}

@media (min-font-size: 200%) {
  page {
    --font-body: 34rpx;
    --font-display: 40rpx;
  }

  /* 听障模式下保持单列布局 */
  page.mode-deaf .grid-item,
  page.mode-deaf .grid-3 .grid-item {
    flex: 0 0 calc(100% - var(--space-4));
    margin: var(--space-3) var(--space-2);
  }
}

/* 弹性文字容器：防止文字溢出 */
.text-wrap {
  word-wrap: break-word;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 最小触摸区域 */
.touch-target {
  min-width: 88rpx;
  min-height: 88rpx;
}

/* 全宽按钮 */
.btn-block {
  width: 100%;
}

/* 隐藏元素 */
.hidden { display: none !important; }
.invisible { visibility: hidden; }

/* 屏幕阅读器专用（ visually hidden but accessible ） */
.sr-only {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  padding: 0;
  margin: -1rpx;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ===== 隐藏滚动条 ===== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ===== 无障碍：减少动画 ===== */
@media (prefers-reduced-motion: reduce) {
  page,
  view,
  text,
  button,
  image,
  scroll-view,
  swiper,
  swiper-item,
  movable-area,
  movable-view,
  cover-view,
  cover-image {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* 手动减少动画模式（通过类名） */
page.reduce-motion,
page.reduce-motion view,
page.reduce-motion text,
page.reduce-motion image,
page.reduce-motion button,
page.reduce-motion scroll-view,
page.reduce-motion swiper,
page.reduce-motion swiper-item,
page.reduce-motion movable-area,
page.reduce-motion movable-view,
page.reduce-motion cover-view,
page.reduce-motion cover-image,
page.reduce-motion ::before,
page.reduce-motion ::after {
  animation-duration: 0.01ms !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0.01ms !important;
  scroll-behavior: auto !important;
}

/* ===== 高对比度模式 ===== */
@media (prefers-contrast: high) {
  page {
    --text-primary: #000000 !important;
    --text-secondary: #333333 !important;
    --text-tertiary: #666666 !important;
    --bg-primary: #FFFFFF !important;
    --bg-secondary: #F0F0F0 !important;
    --brand: #0044AA !important;
    --brand-light: #E6F2FF !important;
    --accent: #FF6600 !important;
    --border: #000000 !important;
  }

  .card {
    border: 2rpx solid #000000 !important;
    box-shadow: none !important;
  }

  .btn-primary {
    border: 2rpx solid #000000 !important;
  }
}

/* 手动高对比度模式（通过类名） */
page.high-contrast {
  --text-primary: #000000;
  --text-secondary: #333333;
  --text-tertiary: #666666;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F0F0F0;
  --brand: #0044AA;
  --brand-light: #E6F2FF;
  --accent: #FF6600;
  --border: #000000;
}

page.high-contrast .card {
  border: 2rpx solid #000000;
  box-shadow: none;
}

page.high-contrast .btn-primary {
  border: 2rpx solid #000000;
}

/* ===== 字体放大适配（200%） ===== */
@media (min-font-size: 200%) {
  page {
    --font-body: 34rpx;
    --font-display: 40rpx;
  }
}

/* ===== 听障模式全局样式 ===== */
page.mode-deaf {
  --font-body: var(--font-deaf-body);
  --font-display: var(--font-deaf-display);
}

page.mode-deaf .text-body {
  font-size: var(--font-deaf-body);
  line-height: var(--leading-deaf);
}

page.mode-deaf .text-display {
  font-size: var(--font-deaf-display);
  line-height: 1.4;
}

page.mode-deaf .text-caption {
  font-size: 28rpx;
  line-height: var(--leading-deaf);
}

/* 听障模式按钮增大 */
page.mode-deaf .btn {
  min-height: 96rpx;
  padding: var(--space-3) var(--space-5);
  font-size: var(--font-deaf-body);
}

page.mode-deaf .btn-large {
  min-height: 120rpx;
  font-size: var(--font-deaf-display);
  border-radius: 60rpx;
}

/* 听障模式卡片增大间距 */
page.mode-deaf .card {
  padding: var(--space-5);
  margin-bottom: var(--space-4);
}

/* 听障模式输入框 */
page.mode-deaf .input-minimal {
  font-size: var(--font-deaf-body);
  min-height: 120rpx;
}

page.mode-deaf .input-deaf {
  font-size: var(--font-deaf-display);
  line-height: var(--leading-deaf);
  min-height: 200rpx;
}

/* 听障模式图标增大 */
page.mode-deaf .icon {
  width: 56rpx;
  height: 56rpx;
}

page.mode-deaf .icon-large {
  width: 80rpx;
  height: 80rpx;
}

/* 听障模式芯片 */
page.mode-deaf .chip {
  padding: 24rpx 36rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
}

/* 听障模式列表项 */
page.mode-deaf .list-item {
  padding: var(--space-4) 0;
  min-height: 120rpx;
}

/* 听障模式导航 */
page.mode-deaf .nav-item {
  padding: var(--space-3) var(--space-4);
  font-size: var(--font-deaf-body);
}

/* 听障模式标签 */
page.mode-deaf .label {
  font-size: var(--font-deaf-body);
  margin-bottom: var(--space-3);
}

/* 听障模式分隔 */
page.mode-deaf .divider {
  margin: var(--space-4) 0;
  height: 2rpx;
}
