/**app.wxss**/

/* ===== 语见设计系统 v2.0：温暖、专业、现代 ===== */
/* 设计理念：医疗级专业感 + 人文关怀温度 + 现代极简美学 */

page {
  /* ===== 色彩系统：温暖疗愈调色板 ===== */
  /* 主背景 - 暖调米白，如晨光般柔和 */
  --bg-warm: #FDFBF8;
  --bg-primary: var(--bg-warm);
  --bg-secondary: #F5F2EE;
  --bg-tertiary: #EBE8E4;
  --bg-elevated: #FFFFFF;
  --bg-card: #FFFFFF;

  /* 品牌色系 - 宁静蓝灰，医疗专业感 */
  --brand-primary: #6B8E9F;
  --brand-secondary: #8BA5B3;
  --brand-light: #E8F0F4;
  --brand-soft: #F5F9FB;
  --brand-dark: #4A6B7C;

  /* 强调色系 - 温暖琥珀，生命力 */
  --accent-warm: #D4A574;
  --accent-soft: #E8D4BC;
  --accent-light: #F5EBE0;
  --accent-dark: #B8935F;

  /* 关怀绿 - 心理健康、希望 */
  --care-green: #7CA68C;
  --care-green-light: #E8F3EC;
  --care-green-soft: #F0F7F2;

  /* 语义色彩 */
  --urgent: #C98B6E;
  --urgent-light: #F5E8E2;
  --daily: #7A9AAA;
  --daily-light: #E8F0F3;
  --biz: #9A9A9A;
  --biz-light: #F0F0F0;

  /* 文字色系 - 高可读性层次 */
  --text-primary: #2C3E44;
  --text-secondary: #5A6B72;
  --text-tertiary: #8A9AA1;
  --text-muted: #B8C4C8;
  --text-inverse: #FFFFFF;
  --text-placeholder: #AAB8BE;

  /* 兼容性映射（保留旧变量名） */
  --bg-warm: var(--bg-primary);
  --morandi-blue: var(--brand-primary);
  --morandi-blue-light: var(--brand-light);
  --morandi-blue-dark: var(--brand-dark);
  --morandi-amber: var(--accent-warm);
  --morandi-amber-light: var(--accent-soft);
  --morandi-amber-dark: var(--accent-dark);
  --morandi-gray: var(--text-tertiary);
  --morandi-gray-light: var(--text-muted);
  --brand: var(--brand-primary);
  --brand-light: var(--brand-light);
  --accent: var(--accent-warm);
  --deaf-urgent: var(--urgent);
  --deaf-daily: var(--daily);
  --deaf-biz: var(--biz);

  /* ===== 渐变系统：柔和光感 ===== */
  --gradient-primary: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
  --gradient-warm: linear-gradient(135deg, var(--accent-warm) 0%, var(--accent-soft) 100%);
  --gradient-care: linear-gradient(135deg, var(--care-green) 0%, #9BC4AA 100%);
  --gradient-urgent: linear-gradient(135deg, var(--urgent) 0%, #D4A090 100%);
  --gradient-daily: linear-gradient(135deg, var(--daily) 0%, var(--brand-secondary) 100%);
  --gradient-biz: linear-gradient(135deg, #8A9AA0 0%, var(--biz) 100%);
  --gradient-voice: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-dark) 100%);
  --gradient-glass: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 100%);

  /* ===== 间距系统：8rpx 基准，黄金比例 ===== */
  --space-unit: 8rpx;
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --space-6: 64rpx;
  --space-7: 80rpx;
  --space-8: 96rpx;

  /* ===== 圆角系统：超柔和大圆角 ===== */
  --radius-sm: 12rpx;
  --radius: 20rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-2xl: 48rpx;
  --radius-full: 9999rpx;

  /* ===== 阴影系统：层次分明的光感 ===== */
  --shadow-xs: 0 1rpx 2rpx rgba(44, 62, 68, 0.04);
  --shadow-sm: 0 2rpx 8rpx rgba(44, 62, 68, 0.06);
  --shadow: 0 4rpx 16rpx rgba(44, 62, 68, 0.08);
  --shadow-md: 0 8rpx 24rpx rgba(44, 62, 68, 0.1);
  --shadow-lg: 0 12rpx 40rpx rgba(44, 62, 68, 0.12);
  --shadow-xl: 0 20rpx 60rpx rgba(44, 62, 68, 0.15);
  --shadow-glow: 0 0 40rpx rgba(107, 142, 159, 0.15);
  --shadow-warm: 0 8rpx 32rpx rgba(212, 165, 116, 0.2);

  /* ===== 动画系统：丝滑流畅 ===== */
  --duration-instant: 100ms;
  --duration-fast: 200ms;
  --duration-normal: 300ms;
  --duration-slow: 500ms;
  --duration-slower: 700ms;

  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-in-out: cubic-bezier(0.45, 0, 0.55, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);

  /* ===== 字体系统：清晰易读 ===== */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;

  --font-display: var(--font-xl);
  --font-body: var(--font-base);
  --font-caption: var(--font-sm);

  /* 听障模式字号 */
  --font-deaf-body: 34rpx;
  --font-deaf-display: 40rpx;
  --leading-deaf: 1.8;

  /* 兼容性映射 */
  --text-display: var(--font-display);
  --text-body: var(--font-body);
  --text-caption: var(--font-caption);
  --text-deaf-body: var(--font-deaf-body);
  --text-deaf-display: var(--font-deaf-display);

  /* ===== 无障碍常量 ===== */
  --touch-min: 88rpx;
  --focus-ring: 0 0 0 4rpx rgba(107, 142, 159, 0.3);
}

/* ===== 基础重置 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  background: var(--bg-primary);
  line-height: 1.6;
  min-height: 100vh;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ===== 页面容器 ===== */
.page-full {
  min-height: 100vh;
  background: var(--bg-primary);
  box-sizing: border-box;
}

.page-enter {
  animation: pageEnter var(--duration-slow) var(--ease-smooth);
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 卡片系统：多层次 ===== */
.card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-fast) var(--ease-out);
}

.card-hover:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow);
}

.card-elevated {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
}

.card-soft {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
}

.card-bordered {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 2rpx solid var(--bg-tertiary);
}

/* ===== 玻璃拟态 ===== */
.glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-xl);
}

.glass-dark {
  background: rgba(44, 62, 68, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-xl);
}

/* ===== 按钮系统：现代胶囊 ===== */
.btn-capsule {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: var(--radius-full);
  padding: 0 var(--space-5);
  font-size: var(--font-md);
  font-weight: 600;
  transition: all var(--duration-fast) var(--ease-out);
  border: none;
  color: #FFFFFF;
  white-space: nowrap;
  min-width: 200rpx;
  box-shadow: var(--shadow-sm);
}

.btn-capsule:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-xs);
}

.btn-capsule text,
.btn-capsule .btn-text {
  color: #FFFFFF !important;
  white-space: nowrap;
}

/* 按钮变体 */
.btn-primary {
  background: var(--gradient-primary);
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
}

.btn-warm {
  background: var(--gradient-warm);
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.35);
}

.btn-care {
  background: var(--gradient-care);
  box-shadow: 0 4rpx 16rpx rgba(124, 166, 140, 0.35);
}

.btn-urgent {
  background: var(--gradient-urgent);
  box-shadow: 0 4rpx 16rpx rgba(201, 139, 110, 0.35);
}

.btn-daily {
  background: var(--gradient-daily);
  box-shadow: 0 4rpx 16rpx rgba(122, 154, 170, 0.35);
}

.btn-biz {
  background: var(--gradient-biz);
  box-shadow: 0 4rpx 16rpx rgba(138, 154, 160, 0.35);
}

/* 次级按钮 */
.btn-secondary {
  background: var(--bg-elevated);
  color: var(--text-primary) !important;
  border: 2rpx solid var(--bg-tertiary);
  box-shadow: var(--shadow-xs);
}

.btn-secondary text,
.btn-secondary .btn-text {
  color: var(--text-primary) !important;
}

.btn-secondary:active {
  background: var(--bg-secondary);
}

/* 幽灵按钮 */
.btn-ghost {
  background: transparent;
  color: var(--brand-primary) !important;
  border: 2rpx solid var(--brand-light);
}

.btn-ghost text,
.btn-ghost .btn-text {
  color: var(--brand-primary) !important;
}

.btn-ghost:active {
  background: var(--brand-soft);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--brand-primary) !important;
  box-shadow: none;
  height: auto;
  padding: var(--space-2) var(--space-3);
  font-weight: 500;
}

.btn-text .btn-text {
  color: var(--brand-primary) !important;
}

.btn-text:active {
  background: var(--brand-soft);
  transform: none;
}

/* ===== 圆形语音按钮 ===== */
.voice-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-voice);
  box-shadow: var(--shadow-lg), var(--shadow-glow);
  transition: all var(--duration-normal) var(--ease-out);
  position: relative;
  overflow: hidden;
}

.voice-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.25), transparent 60%);
  border-radius: 50%;
}

.voice-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.voice-btn.recording {
  animation: voicePulse 1.5s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% {
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    transform: scale(1);
  }
  50% {
    box-shadow: var(--shadow-xl), 0 0 60rpx rgba(107, 142, 159, 0.3);
    transform: scale(1.03);
  }
}

/* ===== 模式切换器 ===== */
.mode-switcher {
  height: 88rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  padding: 6rpx;
  display: flex;
  position: relative;
  width: 360rpx;
}

.mode-option {
  flex: 1;
  height: 76rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  color: var(--text-secondary);
  transition: all var(--duration-normal) var(--ease-spring);
  z-index: 1;
  font-weight: 500;
}

.mode-option.active {
  background: #FFFFFF;
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
  font-weight: 600;
}

/* ===== 输入框系统 ===== */
.input-minimal {
  border: none;
  border-bottom: 2rpx solid var(--bg-tertiary);
  border-radius: 0;
  padding: var(--space-3) 0;
  font-size: var(--font-body);
  color: var(--text-primary);
  background: transparent;
  transition: border-color var(--duration-fast);
  width: 100%;
}

.input-minimal:focus {
  border-bottom-color: var(--brand-primary);
}

.input-minimal::placeholder {
  color: var(--text-placeholder);
}

.input-soft {
  background: var(--bg-secondary);
  border: 2rpx solid transparent;
  border-radius: var(--radius);
  padding: var(--space-3) var(--space-4);
  font-size: var(--font-body);
  color: var(--text-primary);
  transition: all var(--duration-fast);
  width: 100%;
}

.input-soft:focus {
  background: var(--bg-elevated);
  border-color: var(--brand-light);
  box-shadow: var(--shadow-sm);
}

.input-soft::placeholder {
  color: var(--text-placeholder);
}

/* ===== 标签芯片 ===== */
.chip {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: 500;
  transition: all var(--duration-fast);
}

.chip:active {
  transform: scale(0.96);
}

.chip-primary {
  background: var(--brand-light);
  color: var(--brand-dark);
}

.chip-warm {
  background: var(--accent-light);
  color: var(--accent-dark);
}

.chip-care {
  background: var(--care-green-light);
  color: var(--care-green);
}

.chip-urgent {
  background: var(--urgent-light);
  color: var(--urgent);
}

.chip-daily {
  background: var(--daily-light);
  color: var(--daily);
}

.chip-biz {
  background: var(--biz-light);
  color: var(--biz);
}

.chip-outline {
  background: transparent;
  border: 2rpx solid var(--bg-tertiary);
  color: var(--text-secondary);
}

/* ===== 图标系统 ===== */
.icon {
  width: 48rpx;
  height: 48rpx;
}

.icon-sm {
  width: 36rpx;
  height: 36rpx;
}

.icon-md {
  width: 48rpx;
  height: 48rpx;
}

.icon-lg {
  width: 64rpx;
  height: 64rpx;
}

.icon-xl {
  width: 80rpx;
  height: 80rpx;
}

/* ===== 文字工具类 ===== */
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-base { font-size: var(--font-base); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-2xl { font-size: var(--font-2xl); }
.text-3xl { font-size: var(--font-3xl); }

.text-display { font-size: var(--font-display); font-weight: 700; line-height: 1.3; }
.text-body { font-size: var(--font-body); line-height: 1.6; }
.text-caption { font-size: var(--font-caption); color: var(--text-secondary); }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-muted { color: var(--text-muted); }
.text-brand { color: var(--brand-primary); }
.text-accent { color: var(--accent-warm); }
.text-care { color: var(--care-green); }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* ===== 弹性布局工具类 ===== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-nowrap { flex-wrap: nowrap; }
.flex-1 { flex: 1; }
.flex-auto { flex: auto; }
.flex-none { flex: none; }

.items-start { align-items: flex-start; }
.items-center { align-items: center; }
.items-end { align-items: flex-end; }
.items-stretch { align-items: stretch; }

.justify-start { justify-content: flex-start; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-evenly { justify-content: space-evenly; }

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ===== 间距工具类 ===== */
.m-1 { margin: var(--space-1); }
.m-2 { margin: var(--space-2); }
.m-3 { margin: var(--space-3); }
.m-4 { margin: var(--space-4); }
.m-5 { margin: var(--space-5); }
.m-6 { margin: var(--space-6); }

.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mt-5 { margin-top: var(--space-5); }
.mt-6 { margin-top: var(--space-6); }

.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-5 { margin-bottom: var(--space-5); }
.mb-6 { margin-bottom: var(--space-6); }

.ml-1 { margin-left: var(--space-1); }
.ml-2 { margin-left: var(--space-2); }
.ml-3 { margin-left: var(--space-3); }
.ml-4 { margin-left: var(--space-4); }
.ml-5 { margin-left: var(--space-5); }
.ml-6 { margin-left: var(--space-6); }

.mr-1 { margin-right: var(--space-1); }
.mr-2 { margin-right: var(--space-2); }
.mr-3 { margin-right: var(--space-3); }
.mr-4 { margin-right: var(--space-4); }
.mr-5 { margin-right: var(--space-5); }
.mr-6 { margin-right: var(--space-6); }

.mx-1 { margin-left: var(--space-1); margin-right: var(--space-1); }
.mx-2 { margin-left: var(--space-2); margin-right: var(--space-2); }
.mx-3 { margin-left: var(--space-3); margin-right: var(--space-3); }
.mx-4 { margin-left: var(--space-4); margin-right: var(--space-4); }
.mx-5 { margin-left: var(--space-5); margin-right: var(--space-5); }
.mx-6 { margin-left: var(--space-6); margin-right: var(--space-6); }

.my-1 { margin-top: var(--space-1); margin-bottom: var(--space-1); }
.my-2 { margin-top: var(--space-2); margin-bottom: var(--space-2); }
.my-3 { margin-top: var(--space-3); margin-bottom: var(--space-3); }
.my-4 { margin-top: var(--space-4); margin-bottom: var(--space-4); }
.my-5 { margin-top: var(--space-5); margin-bottom: var(--space-5); }
.my-6 { margin-top: var(--space-6); margin-bottom: var(--space-6); }

.p-1 { padding: var(--space-1); }
.p-2 { padding: var(--space-2); }
.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }
.p-5 { padding: var(--space-5); }
.p-6 { padding: var(--space-6); }

.pt-1 { padding-top: var(--space-1); }
.pt-2 { padding-top: var(--space-2); }
.pt-3 { padding-top: var(--space-3); }
.pt-4 { padding-top: var(--space-4); }
.pt-5 { padding-top: var(--space-5); }
.pt-6 { padding-top: var(--space-6); }

.pb-1 { padding-bottom: var(--space-1); }
.pb-2 { padding-bottom: var(--space-2); }
.pb-3 { padding-bottom: var(--space-3); }
.pb-4 { padding-bottom: var(--space-4); }
.pb-5 { padding-bottom: var(--space-5); }
.pb-6 { padding-bottom: var(--space-6); }

.pl-1 { padding-left: var(--space-1); }
.pl-2 { padding-left: var(--space-2); }
.pl-3 { padding-left: var(--space-3); }
.pl-4 { padding-left: var(--space-4); }
.pl-5 { padding-left: var(--space-5); }
.pl-6 { padding-left: var(--space-6); }

.pr-1 { padding-right: var(--space-1); }
.pr-2 { padding-right: var(--space-2); }
.pr-3 { padding-right: var(--space-3); }
.pr-4 { padding-right: var(--space-4); }
.pr-5 { padding-right: var(--space-5); }
.pr-6 { padding-right: var(--space-6); }

.px-1 { padding-left: var(--space-1); padding-right: var(--space-1); }
.px-2 { padding-left: var(--space-2); padding-right: var(--space-2); }
.px-3 { padding-left: var(--space-3); padding-right: var(--space-3); }
.px-4 { padding-left: var(--space-4); padding-right: var(--space-4); }
.px-5 { padding-left: var(--space-5); padding-right: var(--space-5); }
.px-6 { padding-left: var(--space-6); padding-right: var(--space-6); }

.py-1 { padding-top: var(--space-1); padding-bottom: var(--space-1); }
.py-2 { padding-top: var(--space-2); padding-bottom: var(--space-2); }
.py-3 { padding-top: var(--space-3); padding-bottom: var(--space-3); }
.py-4 { padding-top: var(--space-4); padding-bottom: var(--space-4); }
.py-5 { padding-top: var(--space-5); padding-bottom: var(--space-5); }
.py-6 { padding-top: var(--space-6); padding-bottom: var(--space-6); }

/* ===== 安全区域 ===== */
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 容器 ===== */
.container {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: var(--space-4);
  box-sizing: border-box;
}

.container-sm {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: var(--space-3);
  box-sizing: border-box;
}

.container-lg {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: var(--space-5);
  box-sizing: border-box;
}

/* ===== 网格布局 ===== */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}

/* ===== 加载动画 ===== */
.loading-pulse {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}

.loading-pulse::before,
.loading-pulse::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: var(--brand-primary);
  opacity: 0.3;
  animation: subtlePulse 2s ease-in-out infinite;
}

.loading-pulse::after {
  animation-delay: 1s;
}

@keyframes subtlePulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.3;
  }
  50% {
    transform: scale(1.15);
    opacity: 0.5;
  }
}

/* ===== 波纹效果 ===== */
.ripple-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--brand-primary);
  opacity: 0.4;
  animation: rippleExpand 800ms ease-out forwards;
}

@keyframes rippleExpand {
  to {
    transform: translate(-50%, -50%) scale(1.6);
    opacity: 0;
  }
}

/* ===== 按压反馈 ===== */
.press {
  transition: all var(--duration-fast) var(--ease-out);
}

.press:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* ===== 文字截断 ===== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.text-ellipsis-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 触摸目标 ===== */
.touch-target {
  min-width: var(--touch-min);
  min-height: var(--touch-min);
}

/* ===== 隐藏元素 ===== */
.hidden { display: none !important; }
.invisible { visibility: hidden; }
.sr-only {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  padding: 0;
  margin: -1rpx;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ===== 滚动条隐藏 ===== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ===== 减少动画 ===== */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* ===== 高对比度模式 ===== */
@media (prefers-contrast: high) {
  page {
    --text-primary: #000000;
    --text-secondary: #333333;
    --bg-primary: #FFFFFF;
    --brand-primary: #0044AA;
  }

  .card {
    border: 2rpx solid #000000;
    box-shadow: none;
  }
}

/* ===== 听障模式全局样式 ===== */
page.mode-deaf {
  --font-body: var(--font-deaf-body);
  --font-display: var(--font-deaf-display);
}

page.mode-deaf .text-body {
  font-size: var(--font-deaf-body);
  line-height: var(--leading-deaf);
}

page.mode-deaf .text-display {
  font-size: var(--font-deaf-display);
}

page.mode-deaf .btn-capsule {
  height: 104rpx;
  font-size: var(--font-deaf-body);
}

page.mode-deaf .card {
  padding: var(--space-5);
}

page.mode-deaf .input-soft {
  font-size: var(--font-deaf-body);
  padding: var(--space-4);
}

page.mode-deaf .icon {
  width: 56rpx;
  height: 56rpx;
}

/* ===== 旧变量兼容性保留 ===== */
.radius-sm { border-radius: var(--radius-sm); }
.radius { border-radius: var(--radius); }
.radius-lg { border-radius: var(--radius-lg); }
.radius-xl { border-radius: var(--radius-xl); }
.radius-full { border-radius: var(--radius-full); }

.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow { box-shadow: var(--shadow); }
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }
