.smpl-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: #F8FAFF;
  z-index: 1000;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.smpl-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(env(safe-area-inset-top) + 16rpx) 24rpx 16rpx;
  z-index: 1002;
  box-sizing: border-box;
}

.smpl-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.handle-bar {
  width: 80rpx;
  height: 10rpx;
  background: rgba(0,0,0,0.22);
  border-radius: 5rpx;
}

.loading-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.ripple-group {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.water-ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(0, 122, 255, 0.25);
  animation: waterRipple 2s ease-out infinite;
}

.water-ripple.delay-1 {
  animation-delay: 0.6s;
}

.water-ripple.delay-2 {
  animation-delay: 1.2s;
}

@keyframes waterRipple {
  0% { width: 60rpx; height: 60rpx; opacity: 0.6; }
  100% { width: 200rpx; height: 200rpx; opacity: 0; }
}

.loading-text {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  animation: breathe 2s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* Error State */
.error-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  background: #F8FAFF;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--text);
  margin-bottom: 16rpx;
}

.error-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 生成中状态 */
.generating-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  background: #F8FAFF;
}

.progress-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.progress-ring {
  position: relative;
}

.progress-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(91, 123, 163, 0.15);
}

.progress-inner {
  width: 200rpx;
  height: 200rpx;
  background: #F8FAFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-percent {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--morandi-blue, #5B7BA3);
}

.generating-text {
  font-size: 32rpx;
  color: var(--text-primary, #2D2D2D);
  font-weight: 500;
}

.generating-hint {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
}

.retry-btn {
  margin-top: 40rpx;
  padding: 20rpx 48rpx;
  background: var(--morandi-blue, #5B7BA3);
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
}

/* 取消生成按钮 */
.cancel-btn {
  margin-top: 60rpx;
  padding: 24rpx 48rpx;
  background: rgba(255, 77, 79, 0.1);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #ff4d4f;
  transition: all 0.2s ease;
}

.cancel-btn:active {
  background: rgba(255, 77, 79, 0.2);
  transform: scale(0.98);
}

.cancel-icon {
  font-size: 24rpx;
  font-weight: 600;
}

/* Content Area - 中间内容区 */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center; /* 垂直居中 */
  padding: 200rpx 40rpx 360rpx; /* 底部留出更多空间给原文区域 */
  box-sizing: border-box;
}

/* Video Container - 视频容器 */
.video-container {
  width: 92%;
  height: 60vh; /* 更大一点，占屏幕60% */
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent; /* 去掉黑色背景 */
  border-radius: 12rpx;
  overflow: hidden;
}

.smpl-video {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

/* 3D Canvas */
.webgl-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 原文展示区域 */
.original-text-section {
  position: absolute;
  left: 0;
  bottom: 320rpx;
  width: 100%;
  padding: 16rpx 40rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid rgba(0,0,0,0.06);
  z-index: 1002;
  box-sizing: border-box;
}

.original-text-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.original-text-content {
  max-height: 100rpx;
}

.original-text {
  font-size: 34rpx;
  color: #2D2D2D;
  line-height: 1.7;
  word-break: break-all;
  white-space: pre-wrap;
}

/* Bottom Controls - 底部控制按钮 */
.viewer-controls {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 300rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding-bottom: calc(env(safe-area-inset-bottom) + 60rpx);
  padding-top: 20rpx;
  z-index: 1001;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.control-btn {
  padding: 20rpx 36rpx;
  font-size: 26rpx;
  color: var(--text);
  border-radius: 36rpx;
  background: rgba(0,122,255,0.08);
  text-align: center;
  min-width: 120rpx;
}

.control-btn.back {
  background: rgba(0,0,0,0.06);
}
