.smpl-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: #F8FAFF;
  z-index: 1000;
  overflow: hidden;
}

.smpl-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(env(safe-area-inset-top) + 16rpx) 24rpx 16rpx;
  z-index: 1002;
  box-sizing: border-box;
}

.smpl-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.handle-bar {
  width: 80rpx;
  height: 10rpx;
  background: rgba(0,0,0,0.22);
  border-radius: 5rpx;
}

.loading-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.ripple-group {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.water-ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(0, 122, 255, 0.25);
  animation: waterRipple 2s ease-out infinite;
}

.water-ripple.delay-1 {
  animation-delay: 0.6s;
}

.water-ripple.delay-2 {
  animation-delay: 1.2s;
}

@keyframes waterRipple {
  0% { width: 60rpx; height: 60rpx; opacity: 0.6; }
  100% { width: 200rpx; height: 200rpx; opacity: 0; }
}

.loading-text {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  animation: breathe 2s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.webgl-canvas {
  width: 100vw;
  height: 100vh;
  display: block;
}

.text-bubble {
  position: absolute;
  left: 50%;
  bottom: 200rpx;
  transform: translateX(-50%);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(255,255,255,0.6);
  max-width: 80%;
  z-index: 1001;
}

.bubble-text {
  font-size: 30rpx;
  color: var(--text);
  text-align: center;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.viewer-controls {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 140rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1001;
}

.control-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: var(--text);
  border-radius: 32rpx;
  background: rgba(0,122,255,0.08);
}
