.mode-capsule {
  position: relative;
  display: flex;
  align-items: center;
  width: 320rpx;
  height: 72rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 122, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  margin: 0 auto;
}

.mode-highlight {
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 152rpx;
  height: 64rpx;
  background: #E3F2FD;
  border-radius: 32rpx;
  transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.mode-highlight.right {
  transform: translateX(160rpx);
}

.mode-highlight.spring {
  animation: springScale 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes springScale {
  0% { transform: scaleX(1) translateX(0); }
  40% { transform: scaleX(1.08) translateX(0); }
  100% { transform: scaleX(1) translateX(0); }
}

.mode-highlight.right.spring {
  animation: springScaleRight 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes springScaleRight {
  0% { transform: scaleX(1) translateX(160rpx); }
  40% { transform: scaleX(1.08) translateX(160rpx); }
  100% { transform: scaleX(1) translateX(160rpx); }
}

.mode-item {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  z-index: 2;
  transition: all 200ms ease;
}

.mode-item.active {
  color: #1A1A2E;
  font-weight: 600;
}
