/* 导航栏 */
.custom-navbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 100rpx;
  color: #999;
  transition: color 200ms;
}

.tab-item.active {
  color: #1a1a2e;
}

.tab-image {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.5;
  transition: opacity 200ms;
}

.tab-item.active .tab-image {
  opacity: 1;
}

.tab-text {
  font-size: 20rpx;
}
