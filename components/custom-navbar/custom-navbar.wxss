/* 自定义导航栏 - 玻璃拟态 */
.custom-navbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

/* 导航项 */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  color: #9ca3af;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
}

/* 活跃状态 */
.tab-item.active {
  color: #6366f1;
  transform: translateY(-8rpx);
}

/* 图标容器 */
.icon-wrapper {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.tab-image {
  width: 48rpx;
  height: 48rpx;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  opacity: 0.6;
}

.tab-item.active .tab-image {
  opacity: 1;
  transform: scale(1.1);
  filter: drop-shadow(0 4rpx 12rpx rgba(99, 102, 241, 0.4));
}

/* 活跃指示器 */
.tab-item.active .icon-wrapper::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 2rpx;
  animation: indicatorIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes indicatorIn {
  from {
    opacity: 0;
    transform: translateX(-50%) scaleX(0);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) scaleX(1);
  }
}

/* 文字 */
.tab-text {
  font-size: 22rpx;
  margin-top: 8rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.tab-item.active .tab-text {
  font-weight: 600;
}

/* 按压效果 */
.tab-item:active {
  transform: scale(0.95);
}

.tab-item.active:active {
  transform: translateY(-8rpx) scale(0.95);
}

/* 中间按钮特殊样式 - 凸起效果 */
.tab-item:nth-child(2) {
  position: relative;
}

.tab-item:nth-child(2) .icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 50%;
  margin-top: -20rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.4);
}

.tab-item:nth-child(2).active .icon-wrapper {
  transform: scale(1.1);
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.5);
}

.tab-item:nth-child(2) .tab-image {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
  opacity: 1;
}

.tab-item:nth-child(2).active .icon-wrapper::after {
  display: none;
}

.tab-item:nth-child(2) .tab-text {
  margin-top: 4rpx;
}

/* 旧样式兼容 */
.option {
  padding: 10rpx 20rpx;
  cursor: pointer;
}

.option:hover {
  background-color: #f0f0f0;
}
