<view class="forum-container">
  <!-- 头部 -->
  <view class="forum-header">
    <text class="forum-title">{{t('forum.title')}}</text>
    <text class="forum-subtitle">{{t('forum.subtitle')}}</text>
  </view>

  <!-- 帖子列表 -->
  <scroll-view scroll-y="true" class="post-list" bindscrolltolower="loadMore">
    <!-- 合作社区宣传轮播 -->
    <view class="community-banner-section" wx:if="{{communityImages.length > 0}}">
      <text class="section-title">合作社区</text>
      <swiper class="community-swiper" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true">
        <swiper-item wx:for="{{communityImages}}" wx:key="index">
          <view class="community-banner">
            <image src="{{item.path}}" mode="aspectFill" class="banner-image"/>
            <view class="banner-overlay">
              <text class="banner-title">{{item.title}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!posts.length}}">
      <image src="/icons/empty.svg" mode="aspectFit" class="empty-icon"/>
      <text class="empty-text">{{t('forum.empty')}}</text>
    </view>

    <block wx:for="{{posts}}" wx:key="id">
      <view class="post-card" bindtap="viewPost" data-id="{{item.id}}">
        <!-- 分类标签 -->
        <view class="post-category">{{item.category || '分享'}}</view>

        <view class="post-title">{{item.title}}</view>
        <view class="post-content">{{item.content}}</view>

        <!-- 展示第一张图片 -->
        <view wx:if="{{item.images.length}}">
          <image src="{{item.images[0]}}" mode="aspectFill" class="post-image"/>
        </view>

        <view class="post-footer">
          <view class="post-author-wrapper">
            <image class="post-avatar" src="{{item.avatar}}" mode="aspectFill"/>
            <view class="post-author">{{item.author}}</view>
          </view>
          <view class="post-stats">
            <view class="stat-item">
              <image src="/icons/heart.svg" mode="aspectFit" class="stat-icon"/>
              <text>{{item.likes || 0}}</text>
            </view>
            <view class="stat-item">
              <image src="/icons/message.svg" mode="aspectFit" class="stat-icon"/>
              <text>{{item.commentCount}}</text>
            </view>
          </view>
        </view>
        <view class="post-time">{{item.time}}</view>
      </view>
    </block>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{posts.length >= 10}}">加载更多...</view>
  </scroll-view>

  <!-- 发帖按钮 -->
  <view class="new-post-button" bindtap="createPost">
    <image src="/icons/plus.svg" mode="aspectFit" class="new-post-icon"/>
    <text class="new-post-text">{{t('forum.newPost')}}</text>
  </view>
</view>
