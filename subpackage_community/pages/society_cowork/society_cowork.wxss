/* ===== 社区工作：温暖连接设计 ===== */

.container {
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  padding: var(--space-5);
  min-height: 100vh;
  box-sizing: border-box;
}

.phrase-card {
  width: 100%;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-4);
  box-sizing: border-box;
  border: 2rpx solid var(--bg-tertiary);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 700;
  margin-bottom: var(--space-4);
  color: var(--text-primary);
  text-align: left;
  padding-left: var(--space-3);
  border-left: 6rpx solid var(--brand-primary);
}

.content-scroll {
  max-height: 400rpx;
  overflow-y: auto;
}

.small-block {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
  padding: var(--space-4);
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  transition: all var(--duration-fast) var(--ease-out);
}

.small-block:active {
  background: var(--brand-light);
  transform: scale(0.98);
}

.small-block image {
  width: 120rpx;
  height: 90rpx;
  margin-right: var(--space-4);
  border-radius: var(--radius);
  object-fit: cover;
}

.small-block text {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

/* ===== 论坛按钮 ===== */
.community-button {
  width: 100%;
  margin-top: var(--space-3);
  padding: var(--space-5) 0;
  background: var(--gradient-primary);
  color: #fff;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-full);
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(107, 142, 159, 0.35);
  transition: all var(--duration-fast) var(--ease-out);
}

.community-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.25);
}

/* ===== 空状态提示 ===== */
.empty-tip {
  text-align: center;
  padding: var(--space-6);
  color: var(--text-tertiary);
  font-size: var(--font-base);
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .phrase-card {
    border: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .small-block,
  .community-button {
    transition: none;
  }
}
