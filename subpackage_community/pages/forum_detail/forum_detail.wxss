/* ===== 帖子详情：沉浸式阅读设计 ===== */

.detail-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ===== 帖子头部 ===== */
.post-header {
  background: var(--bg-elevated);
  padding: var(--space-5);
  margin-bottom: var(--space-2);
  border-bottom: 2rpx solid var(--bg-tertiary);
}

.category-tag {
  display: inline-block;
  padding: var(--space-1) var(--space-3);
  background: var(--accent-light);
  color: var(--accent-dark);
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-3);
  font-weight: 600;
}

.title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-4);
}

.author-info {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.author-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--brand-light);
  border: 2rpx solid var(--bg-tertiary);
}

.author-meta {
  flex: 1;
}

.author-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.author-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* ===== 帖子内容 ===== */
.content-section {
  background: var(--bg-elevated);
  padding: var(--space-5);
  margin-bottom: var(--space-2);
}

.content {
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.8;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.detail-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius);
}

/* ===== 互动区域 ===== */
.interaction-bar {
  background: var(--bg-elevated);
  padding: var(--space-4) var(--space-5);
  display: flex;
  justify-content: space-around;
  border-bottom: 2rpx solid var(--bg-tertiary);
}

.interaction-btn {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  transition: all var(--duration-fast);
}

.interaction-btn:active {
  transform: scale(0.97);
}

.interaction-btn.active {
  background: var(--accent-light);
}

.interaction-icon {
  width: 36rpx;
  height: 36rpx;
}

.interaction-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

.interaction-btn.active .interaction-text {
  color: var(--accent-dark);
}

/* ===== 评论区 ===== */
.comment-section {
  background: var(--bg-elevated);
  padding: var(--space-5);
  min-height: 400rpx;
}

.comment-header {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 2rpx solid var(--bg-secondary);
}

.comment-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  font-weight: 500;
  margin-left: var(--space-2);
}

.comment-list {
  padding-bottom: var(--space-4);
}

.comment-item {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-3) 0;
  border-bottom: 2rpx solid var(--bg-secondary);
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--brand-light);
  border: 2rpx solid var(--bg-tertiary);
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-author {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.comment-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-left: var(--space-2);
}

.comment-content {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: var(--space-1);
}

.comment-empty {
  text-align: center;
  padding: var(--space-8) var(--space-5);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

/* ===== 评论输入区域 ===== */
.comment-input-area {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: var(--bg-elevated);
  padding: var(--space-3) var(--space-5) calc(var(--space-3) + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--bg-tertiary);
  display: flex;
  gap: var(--space-3);
  align-items: center;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 16rpx rgba(44, 62, 68, 0.05);
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 0 var(--space-5);
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.comment-input::placeholder {
  color: var(--text-placeholder);
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(107, 142, 159, 0.35);
  transition: all var(--duration-fast);
}

.send-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 159, 0.25);
}

.send-text {
  color: #FFFFFF;
  font-size: var(--font-base);
  font-weight: 600;
  line-height: 1;
}

.send-btn.disabled {
  background: var(--text-muted);
  box-shadow: none;
}

.send-btn.disabled .send-text {
  color: #FFFFFF;
}

/* ===== 无障碍样式 ===== */
@media (prefers-contrast: high) {
  .post-header,
  .content-section,
  .interaction-bar,
  .comment-section {
    border: 4rpx solid var(--text-primary);
  }
}

@media (prefers-reduced-motion: reduce) {
  .interaction-btn,
  .send-btn {
    transition: none;
  }
}
