<view class="create-container">
  <!-- 分类选择 -->
  <view class="input-block">
    <text class="input-label">{{t('forum.create.category')}}</text>
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="value"
        class="category-item {{selectedCategory === item.value ? 'active' : ''}}"
        bindtap="selectCategory"
        data-value="{{item.value}}"
      >
        {{t(item.labelKey)}}
      </view>
    </view>
  </view>

  <!-- 标题输入 -->
  <view class="input-block">
    <text class="input-label">{{t('forum.create.title')}}</text>
    <input
      class="input-title"
      placeholder="{{t('forum.create.titlePlaceholder')}}"
      bindinput="onTitleChange"
      value="{{title}}"
    />
  </view>

  <!-- 内容输入 -->
  <view class="input-block">
    <text class="input-label">{{t('forum.comments')}}</text>
    <textarea
      class="input-content"
      placeholder="{{t('forum.create.contentPlaceholder')}}"
      bindinput="onContentChange"
      value="{{content}}"
      maxlength="1000"
    />
  </view>

  <!-- 图片上传 -->
  <view class="image-upload">
    <text class="input-label">{{t('forum.create.addImage')}}</text>
    <view class="image-preview">
      <view class="upload-btn" bindtap="chooseImage">
        <image src="/icons/camera.svg" mode="aspectFit" class="upload-icon"/>
        <text class="upload-text">{{t('forum.create.addImage')}}</text>
      </view>
      <block wx:for="{{images}}" wx:key="*this">
        <view class="preview-item">
          <image src="{{item}}" mode="aspectFill" class="preview-img"/>
          <view class="preview-delete" bindtap="deleteImage" data-index="{{index}}">×</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 发布按钮 -->
  <button class="submit-button {{!canSubmit ? 'disabled' : ''}}" bindtap="submitPost">
    {{t('forum.create.submit')}}
  </button>
</view>
